{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GreenSnapshotDecoder","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"text":"Decoded trees carry a freshly-minted ","type":"text"},{"type":"codeVoice","code":"TokenKeyNamespace"},{"type":"text","text":" that is not"},{"type":"text","text":" "},{"text":"shared with any builder cache. This is fine for read-only consumption","type":"text"},{"text":" ","type":"text"},{"text":"(analysis tools, AST printers, wire-format transport) and for one-shot","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"decode-then-discard workflows."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Load-then-edit caveat.","type":"text"}],"type":"strong"},{"text":" If the decoded tree will subsequently feed","type":"text"},{"text":" ","type":"text"},{"code":"GreenTreeBuilder.reuseSubtree(_:)","type":"codeVoice"},{"text":" from an incremental-parse loop, the","type":"text"},{"text":" ","type":"text"},{"text":"first reuse pays a one-time ","type":"text"},{"code":".remapped","type":"codeVoice"},{"text":" slow path: the source resolver’s","type":"text"},{"text":" ","type":"text"},{"text":"namespace doesn’t match any builder’s cache, so dynamic token keys are","type":"text"},{"text":" ","type":"text"},{"text":"re-interned and the subtree is rebuilt. After that first reparse, the","type":"text"},{"text":" ","type":"text"},{"text":"new tree’s resolver carries the cache’s namespace, and subsequent","type":"text"},{"text":" ","type":"text"},{"text":"reuses fast-path normally.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The total work is the same either way (one O(N) walk in either decode","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or first-reuse). A cache-aware "},{"type":"codeVoice","code":"decodeBuildResult"},{"type":"text","text":" that moves the cost"},{"type":"text","text":" "},{"type":"text","text":"into the load step is technically straightforward but is "},{"inlineContent":[{"text":"deferred","type":"text"},{"text":" ","type":"text"},{"text":"until a real parser\/editor consumer measures the first-edit latency","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"and decides the rebalance is worth the API surface. ","type":"text"},{"code":"SubtreeReuseOutcome","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"from "},{"code":"reuseSubtree","type":"codeVoice"},{"type":"text","text":" is the diagnostic signal: a high "},{"type":"codeVoice","code":".remapped"},{"type":"text","text":" rate"},{"type":"text","text":" "},{"text":"across reparses means the cache lineage is broken (either by this","type":"text"},{"text":" ","type":"text"},{"text":"decoder or by a missing ","type":"text"},{"code":"result.intoCache()","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization"]]},"kind":"symbol","identifier":{"url":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/GreenSnapshotDecoder","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Decoder for the Cambium green-tree snapshot format."}],"topicSections":[{"generated":true,"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/GreenSnapshotDecoder\/decodeSnapshot(_:as:)","doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/GreenSnapshotDecoder\/decodeTree(_:as:)"]}],"metadata":{"symbolKind":"enum","title":"GreenSnapshotDecoder","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GreenSnapshotDecoder","kind":"identifier"}],"