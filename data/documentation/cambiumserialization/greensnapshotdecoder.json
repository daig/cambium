{"identifier":{"url":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/GreenSnapshotDecoder","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Decoder for the Cambium green-tree snapshot format."}],"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambiumserialization\/greensnapshotdecoder"]}],"topicSections":[{"identifiers":["doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/GreenSnapshotDecoder\/decodeSnapshot(_:as:)","doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/GreenSnapshotDecoder\/decodeTree(_:as:)"],"generated":true,"title":"Type Methods","anchor":"Type-Methods"}],"seeAlsoSections":[{"identifiers":["doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/CambiumSerializationError"],"generated":true,"title":"Serialization","anchor":"Serialization"}],"metadata":{"symbolKind":"enum","navigatorTitle":[{"kind":"identifier","text":"GreenSnapshotDecoder"}],"modules":[{"name":"Cambium"}],"roleHeading":"Enumeration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"GreenSnapshotDecoder"}],"title":"GreenSnapshotDecoder","externalID":"s:20CambiumSerialization20GreenSnapshotDecoderO","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"GreenSnapshotDecoder"}]}]},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Decoded trees carry a freshly-minted "},{"code":"TokenKeyNamespace","type":"codeVoice"},{"type":"text","text":" that is not"},{"type":"text","text":" "},{"type":"text","text":"shared with any builder cache. This is fine for read-only consumption"},{"type":"text","text":" "},{"type":"text","text":"(analysis tools, AST printers, wire-format transport) and for one-shot"},{"type":"text","text":" "},{"type":"text","text":"decode-then-discard workflows."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Load-then-edit caveat.","type":"text"}],"type":"strong"},{"type":"text","text":" If the decoded tree will subsequently feed"},{"type":"text","text":" "},{"code":"GreenTreeBuilder.reuseSubtree(_:)","type":"codeVoice"},{"type":"text","text":" from an incremental-parse loop, the"},{"type":"text","text":" "},{"type":"text","text":"first reuse pays a one-time "},{"code":".remapped","type":"codeVoice"},{"type":"text","text":" slow path: the source resolver’s"},{"type":"text","text":" "},{"type":"text","text":"namespace doesn’t match any builder’s cache, so dynamic token keys are"},{"type":"text","text":" "},{"type":"text","text":"re-interned and the subtree is rebuilt. After that first reparse, the"},{"type":"text","text":" "},{"type":"text","text":"new tree’s resolver carries the cache’s namespace, and subsequent"},{"type":"text","text":" "},{"type":"text","text":"reuses fast-path normally."}]},{"type":"paragraph","inlineContent":[{"text":"The total work is the same either way (one O(N) walk in either decode","type":"text"},{"text":" ","type":"text"},{"text":"or first-reuse). A cache-aware ","type":"text"},{"code":"decodeBuildResult","type":"codeVoice"},{"text":" that moves the cost","type":"text"},{"text":" ","type":"text"},{"text":"into the load step is technically straightforward but is ","type":"text"},{"type":"strong","inlineContent":[{"text":"deferred","type":"text"},{"text":" ","type":"text"},{"text":"until a real parser\/editor consumer measures the first-edit latency","type":"text"}]},{"text":" ","type":"text"},{"text":"and decides the rebalance is worth the API surface. ","type":"text"},{"code":"SubtreeReuseOutcome","type":"codeVoice"},{"text":" ","type":"text"},{"text":"from ","type":"text"},{"code":"reuseSubtree","type":"codeVoice"},{"text":" is the diagnostic signal: a high ","type":"text"},{"code":".remapped","type":"codeVoice"},{"text":" rate","type":"text"},{"text":" ","type":"text"},{"text":"across reparses means the cache lineage is broken (either by this","type":"text"},{"text":" ","type":"text"},{"text":"decoder or by a missing ","type":"text"},{"code":"result.intoCache()","type":"codeVoice"},{"text":").","type":"text"}]}],"kind":"content"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","references":{"doc://org.cambium.Cambium/documentation/CambiumSerialization/GreenSnapshotDecoder":{"url":"\/documentation\/cambiumserialization\/greensnapshotdecoder","navigatorTitle":[{"kind":"identifier","text":"GreenSnapshotDecoder"}],"kind":"symbol","role":"symbol","type":"topic","title":"GreenSnapshotDecoder","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"GreenSnapshotDecoder"}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/GreenSnapshotDecoder","abstract":[{"text":"Decoder for the Cambium green-tree snapshot format.","type":"text"}]},"doc://org.cambium.Cambium/documentation/CambiumSerialization/CambiumSerializationError":{"type":"topic","abstract":[{"type":"text","text":"Errors thrown by the green snapshot encoder and decoder."}],"navigatorTitle":[{"kind":"identifier","text":"CambiumSerializationError"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CambiumSerializationError"}],"title":"CambiumSerializationError","kind":"symbol","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSerialization\/CambiumSerializationError","url":"\/documentation\/cambiumserialization\/cambiumserializationerror","role":"symbol"},"doc://org.cambium.Cambium/documentation/CambiumSerialization":{"type":"topic","abstract":[],"title":"CambiumSerialization","kind":"symbol","identifier":"doc:\/\/org.cambium.