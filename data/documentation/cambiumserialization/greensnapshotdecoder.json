{"sections":[],"kind":"symbol","metadata":{"roleHeading":"Enumeration","role":"symbol","externalID":"s:20CambiumSerialization20GreenSnapshotDecoderO","symbolKind":"enum","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"GreenSnapshotDecoder"}],"title":"GreenSnapshotDecoder","navigatorTitle":[{"text":"GreenSnapshotDecoder","kind":"identifier"}],"modules":[{"name":"CambiumSerialization"}]},"abstract":[{"text":"Decoder for the Cambium green-tree snapshot format.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/CambiumSerialization\/documentation\/CambiumSerialization\/GreenSnapshotDecoder"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GreenSnapshotDecoder","kind":"identifier"}]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Decoded trees carry a freshly-minted "},{"type":"codeVoice","code":"TokenKeyNamespace"},{"type":"text","text":" that is not"},{"type":"text","text":" "},{"type":"text","text":"shared with any builder cache. This is fine for read-only consumption"},{"type":"text","text":" "},{"text":"(analysis tools, AST printers, wire-format transport) and for one-shot","type":"text"},{"text":" ","type":"text"},{"text":"decode-then-discard workflows.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Load-then-edit caveat.","type":"text"}],"type":"strong"},{"text":" If the decoded tree will subsequently feed","type":"text"},{"text":" ","type":"text"},{"code":"GreenTreeBuilder.reuseSubtree(_:)","type":"codeVoice"},{"text":" from an incremental-parse loop, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"first reuse pays a one-time "},{"type":"codeVoice","code":".remapped"},{"text":" slow path: the source resolver’s","type":"text"},{"text":" ","type":"text"},{"text":"namespace doesn’t match any builder’s cache, so dynamic token keys are","type":"text"},{"text":" ","type":"text"},{"text":"re-interned and the subtree is rebuilt. After that first reparse, the","type":"text"},{"text":" ","type":"text"},{"text":"new tree’s resolver carries the cache’s namespace, and subsequent","type":"text"},{"text":" ","type":"text"},{"text":"reuses fast-path normally.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The total work is the same either way (one O(N) walk in either decode","type":"text"},{"text":" ","type":"text"},{"text":"or first-reuse). A cache-aware ","type":"text"},{"code":"decodeBuildResult","type":"codeVoice"},{"text":" that moves the cost","type":"text"},{"text":" ","type":"text"},{"text":"into the load step is technically straightforward but is ","type":"text"},{"inlineContent":[{"type":"text","text":"deferred"},{"text":" ","type":"text"},{"text":"until a real parser\/editor consumer measures the first-edit latency","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"and decides the rebalance is worth the API surface. ","type":"text"},{"code":"SubtreeReuseOutcome","type":"codeVoice"},{"type":"text","text":" "},{"text":"from ","type":"text"},{"type":"codeVoice","code":"reuseSubtree"},{"text":" is the diagnostic signal: a high ","type":"text"},{"type":"codeVoice","code":".remapped"},{"text":" rate","type":"text"},{"text":" ","type":"text"},{"text":"across reparses means the cache lineage is broken (either by this","type":"text"},{"text":" ","type":"text"},{"text":"decoder or by a missing ","type":"text"},{"type":"codeVoice","code":"result.intoCache()"},{"type":"text","text":")."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/CambiumSerialization\/documentation\/CambiumSerialization"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/cambiumserialization\/greensnapshotdecoder"],"traits":[{