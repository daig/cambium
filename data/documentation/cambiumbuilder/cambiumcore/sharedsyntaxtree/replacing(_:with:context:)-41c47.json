{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/CambiumCore\/SharedSyntaxTree\/replacing(_:with:context:)-41c47"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"replacing"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"text":"handle","kind":"internalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:11CambiumCore16SyntaxNodeHandleV","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/SyntaxNodeHandle","text":"SyntaxNodeHandle","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"Lang","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"kind":"externalParam","text":"with"},{"text":" ","kind":"text"},{"text":"replacement","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11CambiumCore17ResolvedGreenNodeV","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/ResolvedGreenNode","text":"ResolvedGreenNode","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Lang","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"context","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:14CambiumBuilder16GreenTreeContextV","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/GreenTreeContext","text":"GreenTreeContext","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Lang","kind":"typeIdentifier"},{"text":">) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:11CambiumCore17ReplacementResultV","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/ReplacementResult","text":"ReplacementResult","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Lang","kind":"typeIdentifier"},{"text":">","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"handle"},{"type":"text","text":" must be from this tree; passing a handle from a different"},{"type":"text","text":" "},{"type":"text","text":"tree traps. (Cross-tree replacement is not a meaningful operation —"},{"type":"text","text":" "},{"type":"text","text":"translate the handle through your own tracker first.)"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For full correctness when sharing storage across builders or when"},{"type":"text","text":" "},{"type":"text","text":"the replacement was built independently of this tree, pass a"},{"type":"text","text":" "},{"type":"codeVoice","code":"context"},{"type":"text","text":" whose interner is the one used to build this tree"},{"type":"text","text":" "},{"type":"text","text":"(typically obtained via "},{"type":"codeVoice","code":"result.intoContext()"},{"type":"text","text":"). When the"},{"type":"text","text":" "},{"type":"text","text":"context’s interner shares this tree’s namespace, the result tree’s"},{"type":"text","text":" "},{"type":"text","text":"resolver is the fresh resolver returned by"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/TokenInterner\/makeResolver()"},{"type":"text","text":" covering every key"},{"type":"text","text":" "},{"type":"text","text":"referenced by the new tree."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the target tree shares the context’s interner but the"},{"type":"text","text":" "},{"type":"text","text":"replacement does not, the replacement’s dynamic token keys are"},{"type":"text","text":" "},{"type":"text","text":"remapped into the context’s interner and the result tree carries"},{"type":"text","text":" "},{"type":"text","text":"a fresh resolver from that interner."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In every other case — including the subtle one where the"},{"type":"text","text":" "},{"type":"text","text":"replacement and target share a namespace but the context does"},{"type":"text","text":" "},{"type":"text","text":"not — replacement falls back to an overlay resolver. The overlay"},{"type":"text","text":" "},{"type":"text","text":"preserves structural sharing and correctness (every key in the"},{"type":"text","text":" "},{"type":"text","text":"new tree resolves correctly), but intentionally exposes no"},{"type":"text","text":" "},{"type":"codeVoice","code":"tokenKeyNamespace"},{"type":"text","text":"; future "},{"type":"codeVoice","code":"reuseSubtree"},{"type":"text","text":" calls with a context"},{"type":"text","text":" "},{"type":"text","text":"must remap dynamic token keys instead of direct-reusing the"},{"type":"text","text":" "},{"type":"text","text":"overlay-backed green storage."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder","doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/CambiumCore","doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/CambiumCore\/SharedSyntaxTree"]]},"abstract":[{"type":"text","text":"Replace the subtree at "},{"type":"codeVoice","code":"handle"},{"type":"text","text":" with "},{"type":"codeVoice","code":"replacement"},{"type":"text","text":", producing a new"},{"type":"text","text":" "},{"type":"codeVoice","code":"SyntaxTree"},{"type":"text","text":" and a "},{"type":"codeVoice","code":"ReplacementWitness"},{"type":"text","text":" that describes the structural"},{"type":"text","text":" "},{"type":"text","text":"change. The witness carries enough information for an external"},{"type":"text","text":" "},{"type":"text","text":"identity tracker to translate any v0 reference into v1."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambiumbuilder\/cambiumcore\/sharedsy