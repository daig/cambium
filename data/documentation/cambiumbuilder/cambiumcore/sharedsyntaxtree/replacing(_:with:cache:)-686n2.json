ambiumCore17ResolvedGreenNodeV","text":"ResolvedGreenNode","identifier":"doc:\/\/CambiumCore\/documentation\/CambiumCore\/ResolvedGreenNode","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Lang","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:14CambiumBuilder14GreenNodeCacheV","text":"GreenNodeCache","identifier":"doc:\/\/CambiumBuilder\/documentation\/CambiumBuilder\/GreenNodeCache","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Lang","kind":"typeIdentifier"},{"text":">) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:11CambiumCore17ReplacementResultV","text":"ReplacementResult","identifier":"doc:\/\/CambiumCore\/documentation\/CambiumCore\/ReplacementResult","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Lang","kind":"typeIdentifier"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"code":"handle","type":"codeVoice"},{"text":" must be from this tree; passing a handle from a different","type":"text"},{"text":" ","type":"text"},{"text":"tree traps. (Cross-tree replacement is not a meaningful operation —","type":"text"},{"text":" ","type":"text"},{"text":"translate the handle through your own tracker first.)","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For full correctness when sharing a cache across builders or when","type":"text"},{"text":" ","type":"text"},{"text":"the replacement was built independently of this tree, pass a ","type":"text"},{"code":"cache","type":"codeVoice"},{"text":" ","type":"text"},{"text":"whose interner is the one used to build this tree (typically","type":"text"},{"text":" ","type":"text"},{"text":"obtained via ","type":"text"},{"code":"result.intoCache()","type":"codeVoice"},{"text":"). When the cache shares this","type":"text"},{"text":" ","type":"text"},{"text":"tree’s namespace, the result tree’s resolver is a fresh snapshot of","type":"text"},{"text":" ","type":"text"},{"text":"the cache covering every key referenced by the new tree.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In the rare case where the replacement is in the same namespace as","type":"text"},{"text":" ","type":"text"},{"text":"this tree but the cache passed in is in a different namespace, this","type":"text"},{"text":" ","type":"text"},{"text":"tree’s resolver is reused as-is. If the replacement was taken from","type":"text"},{"text":" ","type":"text"},{"text":"a fresher snapshot of the same shared interner, rendering may","type":"text"},{"text":" ","type":"text"},{"text":"precondition-fail on keys that postdate this tree’s snapshot. Pass","type":"text"},{"text":" ","type":"text"},{"text":"a namespace-matching cache to avoid this.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If neither the replacement nor the cache shares this tree’s namespace,","type":"text"},{"text":" ","type":"text"},{"text":"replacement falls back to an overlay resolver. That fallback preserves","type":"text"},{"text":" ","type":"text"},{"text":"structural sharing and correctness, but intentionally exposes no","type":"text"},{"text":" ","type":"text"},{"code":"tokenKeyNamespace","type":"codeVoice"},{"text":"; future ","type":"text"},{"code":"reuseSubtree","type":"codeVoice"},{"text":" calls with a cache must","type":"text"},{"text":" ","type":"text"},{"text":"remap dynamic token keys instead of direct-reusing the overlay-backed","type":"text"},{"text":" ","type":"text"},{"text":"green storage. Revisit this with the broader cache-lineage redesign.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://CambiumBuilder/documentation/CambiumBuilder/CambiumCore/SharedSyntaxTree":{"kind":"symbol","url":"\/