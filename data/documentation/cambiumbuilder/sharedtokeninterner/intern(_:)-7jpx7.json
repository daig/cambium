{"abstract":[{"text":"Intern a UTF-8 byte sequence and return its ","type":"text"},{"code":"TokenKey","type":"codeVoice"},{"type":"text","text":". Validates"},{"type":"text","text":" "},{"type":"codeVoice","code":"bytes"},{"text":" as UTF-8 on first insertion; throws ","type":"text"},{"code":"TokenTextError.invalidUTF8","type":"codeVoice"},{"text":" ","type":"text"},{"text":"for ill-formed input. Thread-safe.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"externalID":"s:14CambiumBuilder19SharedTokenInternerC6interny0A4Core0D3KeyVSRys5UInt8VGKF","roleHeading":"Instance Method","role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"intern"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"UnsafeBufferPointer","preciseIdentifier":"s:SR"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"TokenKey","preciseIdentifier":"s:11CambiumCore8TokenKeyV"}],"title":"intern(_:)","modules":[{"name":"Cambium"}]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"intern"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"bytes","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SR","kind":"typeIdentifier","text":"UnsafeBufferPointer"},{"kind":"text","text":"<"},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"},{"text":">) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"TokenKey","preciseIdentifier":"s:11CambiumCore8TokenKeyV","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/TokenKey"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Splits the lookup and the insert into two shard-mutex acquisitions so","type":"text"},{"text":" ","type":"text"},{"text":"UTF-8 validation does not run under the lock. Validation is O(n) over","type":"text"},{"text":" ","type":"text"},{"code":"bytes","type":"codeVoice"},{"type":"text","text":"; holding the shard mutex through it would serialize every"},{"type":"text","text":" "},{"type":"text","text":"other thread that hashes to the same shard for the duration of a long"},{"type":"text","text":" "},{"type":"text","text":"token’s validation. The two-acquisition shape keeps both critical"},{"type":"text","text":" "},{"type":"text","text":"sections short (a single dictionary read on the fast path, a"},{"type":"text","text":" "},{"type":"text","text":"re-checked insert on the slow path) at the cost of one extra"},{"type":"text","text":" "},{"type":"text","text":"acquisition per miss. The slow path’s re-check closes the TOCTOU"},{"type":"text","text":" "},{"type":"text","text":"window between the two acquisitions: if another thread inserted the"},{"type":"text","text":" "},{"type":"text","text":"same "},{"type":"codeVoice","code":"keyBytes"},{"type":"text","text":" while we were validating, we return its key."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/SharedTokenInterner\/intern(_:)-7jpx7"},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder","doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/SharedTokenInterner"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambiumbuilder\/sharedtokeninterner\/intern(_:)-7jpx7"]}],"references":{"doc://org.cambium.Cambium/documentation/CambiumBuilder":{"url":"\/docu