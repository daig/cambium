{"identifier":{"url":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/SharedTokenInterner\/intern(_:)-7jpx7","interfaceLanguage":"swift"},"metadata":{"title":"intern(_:)","externalID":"s:14CambiumBuilder19SharedTokenInternerC6interny0A4Core0D3KeyVSRys5UInt8VGKF","modules":[{"name":"Cambium"}],"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"intern","kind":"identifier"},{"text":"(","kind":"text"},{"text":"UnsafeBufferPointer","preciseIdentifier":"s:SR","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"},{"text":">) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"TokenKey","preciseIdentifier":"s:11CambiumCore8TokenKeyV","kind":"typeIdentifier"}],"symbolKind":"method","role":"symbol"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder","doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/SharedTokenInterner"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"intern","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"bytes"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SR","kind":"typeIdentifier","text":"UnsafeBufferPointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier","text":"UInt8"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:11CambiumCore8TokenKeyV","kind":"typeIdentifier","text":"TokenKey","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenKey"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Splits the lookup and the insert into two shard-mutex acquisitions so"},{"type":"text","text":" "},{"type":"text","text":"UTF-8 validation does not run under the lock. Validation is O(n) over"},{"type":"text","text":" "},{"type":"codeVoice","code":"bytes"},{"type":"text","text":"; holding the shard mutex through it would serialize every"},{"type":"text","text":" "},{"type":"text","text":"other thread that hashes to the same shard for the duration of a long"},{"type":"text","text":" "},{"type":"text","text":"token’s validation. The two-acquisition shape keeps both critical"},{"type":"text","text":" "},{"type":"text","text":"sections short (a single dictionary read on the fast path, a"},{"type":"text","text":" "},{"type":"text","text":"re-checked insert on the slow path) at the cost of one extra"},{"type":"text","text":" "},{"text":"acquisition per miss. The slow path’s re-check closes the TOCTOU","type":"text"},{"text":" ","type":"text"},{"text":"window between the two acquisitions: if another thread inserted the","type":"text"},{"text":" ","type":"text"},{"text":"same ","type":"text"},{"type":"codeVoice","code":"keyBytes"},{"text":" while we were validating, we return its key.","type":"text"}]}],"kind":"content"}],"sections":[],"abstract":[{"type":"text","text":"Intern a UTF-8 byte sequence and return its "},{"type":"codeVoice","code":"TokenKey"},{"type":"text","text":". Validates"},{"type":"text","text":" "},{"type":"codeVoice","code":"bytes"},{"type":"text","text":" as UTF-8 on first insertion; throws "},{"type":"codeVoice","code":"TokenTextError.invalidUTF8"},{"type":"text","text":" "},{"type":"text","text":"for ill-formed input. Thread-safe."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambiumbuilder\/sharedtokeninterner\/intern(_:)-7jpx7"]}],"references":{"doc://org.cambium.Cambium/documentation/CambiumBuilder":{"title":"CambiumBuild