haredSyntaxTree.serializeGreenSnapshot()","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"canonicalizes token text into snapshot-local tables, which means a"},{"type":"text","text":" "},{"type":"text","text":"decoded tree’s keys are unrelated to the producer tree’s keys even when"},{"type":"text","text":" "},{"type":"text","text":"the underlying text is identical."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cross-tree reuse.","type":"text"}]},{"type":"text","text":" "},{"code":"CambiumCore\/TokenKeyNamespace","type":"codeVoice"},{"type":"text","text":" is the runtime identity that"},{"type":"text","text":" "},{"type":"text","text":"two trees must share before their token keys can be mixed. Builders"},{"type":"text","text":" "},{"type":"text","text":"inspect the namespace via "},{"code":"CambiumCore\/TokenResolver\/tokenKeyNamespace","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"decide whether "},{"code":"GreenTreeBuilder.reuseSubtree(_:)","type":"codeVoice"},{"type":"text","text":" can splice a green"},{"type":"text","text":" "},{"type":"text","text":"subtree directly or has to remap its dynamic keys into a fresh interner"},{"type":"text","text":" "},{"type":"text","text":"(the slow "},{"code":"SubtreeReuseOutcome.remapped","type":"codeVoice"},{"type":"text","text":" path)."}]}],"kind":"content"}],"references":{"https://github.com/domenicquirl/cstree":{"title":"cstree","url":"https:\/\/github.com\/domenicquirl\/cstree","type":"link","titleInlineContent":[{"type":"codeVoice","code":"cstree"}],"identifier":"https:\/\/github.com\/domenicquirl\/cstree"},"doc://org.cambium.Cambium/documentation/Cambium/TokenKey/RawRepresentable-Implementations":{"kind":"article","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/TokenKey\/RawRepresentable-Implementations","abstract":[],"url":"\/documentation\/cambium\