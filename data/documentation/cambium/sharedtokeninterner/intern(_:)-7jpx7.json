{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"intern"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"bytes"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeBufferPointer","preciseIdentifier":"s:SR"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"TokenKey","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenKey","preciseIdentifier":"s:11CambiumCore8TokenKeyV"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Splits the lookup and the insert into two shard-mutex acquisitions so"},{"type":"text","text":" "},{"type":"text","text":"UTF-8 validation does not run under the lock. Validation is O(n) over"},{"type":"text","text":" "},{"type":"codeVoice","code":"bytes"},{"type":"text","text":"; holding the shard mutex through it would serialize every"},{"type":"text","text":" "},{"type":"text","text":"other thread that hashes to the same shard for the duration of a long"},{"type":"text","text":" "},{"type":"text","text":"token’s validation. The two-acquisition shape keeps both critical"},{"type":"text","text":" "},{"type":"text","text":"sections short (a single dictionary read on the fast path, a"},{"type":"text","text":" "},{"type":"text","text":"re-checked insert on the slow path) at the cost of one extra"},{"type":"text","text":" "},{"type":"text","text":"acquisition per miss. The slow path’s re-check closes the TOCTOU"},{"type":"text","text":" "},{"type":"text","text":"window between the two acquisitions: if another thread inserted the"},{"type":"text","text":" "},{"type":"text","text":"same "},{"type":"codeVoice","code":"keyBytes"},{"type":"text","text":" while we were validating, we return its key."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"intern"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"UnsafeBufferPointer","preciseIdentifier":"s:SR"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"TokenKey","preciseIdentifier":"s:11CambiumCore8TokenKeyV"}],"symbolKind":"method","title":"intern(_:)","externalID":"s:14CambiumBuilder19SharedTokenInternerC6interny0A4Core0D3KeyVSRys5UInt8VGKF","modules":[{"name":"Cambium"}],"roleHeading":"Instance Method"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambium\/sharedtokeninterner\/intern(_:)-7jpx7"]}],"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/Cambium","doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/SharedTokenInterner"]]},"abstract":[{"type":"text","text":"Intern a UTF-8 byte sequence and return its "},{"type":"codeVoice","code":"TokenKey"},{"type":"text","text":". Validates"},{"type":"text","text":" "},{"type":"codeVoice","code":"bytes"},{"type":"text","text":" as UTF-8 on first insertion; throws "},{"type":"codeVoice","code":"TokenTextError.invalidUTF8"},{"type":"text","text":" "},{"type":"text","text":"for ill-formed input. Thread-safe."}],"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/SharedTokenInterner\/intern(_:)-7jpx7","interfaceLanguage":"swift"},"references":{"doc://org.cambium.Cambium/documentation/Cambium":{"title":"Cambium","abstract":[{"text":"A Swift-native co