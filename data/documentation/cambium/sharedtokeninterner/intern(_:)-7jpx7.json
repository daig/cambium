{"kind":"symbol","abstract":[{"text":"Intern a UTF-8 byte sequence and return its ","type":"text"},{"code":"TokenKey","type":"codeVoice"},{"text":". Validates","type":"text"},{"text":" ","type":"text"},{"code":"bytes","type":"codeVoice"},{"text":" as UTF-8 on first insertion; throws ","type":"text"},{"code":"TokenTextError.invalidUTF8","type":"codeVoice"},{"text":" ","type":"text"},{"text":"for ill-formed input. Thread-safe.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/Cambium","doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/SharedTokenInterner"]]},"metadata":{"symbolKind":"method","roleHeading":"Instance Method","externalID":"s:14CambiumBuilder19SharedTokenInternerC6interny0A4Core0D3KeyVSRys5UInt8VGKF","modules":[{"name":"Cambium"}],"title":"intern(_:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"intern"},{"kind":"text","text":"("},{"preciseIdentifier":"s:SR","kind":"typeIdentifier","text":"UnsafeBufferPointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier","text":"UInt8"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:11CambiumCore8TokenKeyV","kind":"typeIdentifier","text":"TokenKey"}]},"variants":[{"paths":["\/documentation\/cambium\/sharedtokeninterner\/intern(_:)-7jpx7"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/SharedTokenInterner\/intern(_:)-7jpx7"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"intern"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"bytes"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SR","kind":"typeIdentifier","text":"UnsafeBufferPointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier","text":"UInt8"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:11CambiumCore8TokenKeyV","kind":"typeIdentifier","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/TokenKey","text":"TokenKey"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Splits the lookup and the insert into two shard-mutex acquisitions so"},{"type":"text","text":" "},{"type":"text","text":"UTF-8 validation does not run under the lock. Validation is O(n) over"},{"type":"text","text":" "},{"type":"codeVoice","code":"bytes"},{"type":"text","text":"; holding the shard mutex through it would serialize every"},{"type":"text","text":" "},{"type":"text","text":"other thread that hashes to the same shard for the duration of a long"},{"type":"text","text":" "},{"type":"text","text":"token’s validation. The two-acquisition shape keeps both critical"},{"type":"text","text":" "},{"type":"text","text":"sections short (a single dictionary read on the fast path, a"},{"type":"text","text":" "},{"type":"text","text":"re-checked insert on the slow path) at the cost of one extra"},{"type":"text","text":" "},{"type":"text","text":"acquisition per miss. The slow path’s re-check closes the TOCTOU"},{"type":"text","text":" "},{"type":"text","text":"window between the two acquisitions: if another thread inserted the"},{"type":"text","text":" "},{"type":"text","text":"same "},{"type":"codeVoice","code":"keyBytes"},{"type":"text","text":" while we were validating, we return its key."}],"type":"paragraph"}]}],"references":{"doc://org.cambium.Cambium/documentation/Cambium":{"type":"topic","title":"Cambium","kind":"symbol","role":"col