ans the cache lineage is broken (either by this","type":"text"},{"text":" ","type":"text"},{"text":"decoder or by a missing ","type":"text"},{"code":"result.intoCache()","type":"codeVoice"},{"text":").","type":"text"}]}]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://org.cambium.Cambium/documentation/Cambium":{"type":"topic","title":"Cambium","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"A Swift-native concrete syntax tree library inspired by Rust’s"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/domenicquirl\/cstree"},{"text":".","type":"text"}],"url":"\/documentation\/cambium","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium"},"https://github.com/domenicquirl/cstree":{"url":"https:\/\/github.com\/domenicquirl\/cstree","title":"cstree","identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"link","titleInlineContent":[{"code":"cstree","type":"codeVoice"}]},"doc://org.cambium.Cambium/documentation/Cambium/GreenSnapshotDecoder/decodeTree(_:as:)":{"url":"\/documentation\/cambium\/greensnapshotdecoder\/decodetree(_:as:)","role":"symbol","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/GreenSnapshotDecoder\/decodeTree(_:as:)","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decodeTree"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Lang"},{"kind":"text","text":">(["},{"preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier","text":"UInt8"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"as"},{"kind":"text","text":": "},{"preciseIdentifier":"s:20CambiumSerialization20GreenSnapshotDecoderO10decodeTree_2as0A4Core06SyntaxG0VyxGSays5UInt8VG_xmtKAF0J8LanguageRzlFZ4LangL_xmfp","kind":"typeIdentifier","text":"Lang"},{"kind":"text","text":".Type) "},{"kind":"keyword","text":"thro