{"abstract":[{"type":"text","text":"A path from a green tree’s root to a descendant node, expressed as the"},{"type":"text","text":" "},{"type":"text","text":"sequence of green child-slot indices (one index per descent step)."}],"kind":"symbol","metadata":{"role":"symbol","externalID":"s:11CambiumCore14SyntaxNodePatha","modules":[{"name":"CambiumSyntaxMacros"}],"fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SyntaxNodePath","kind":"identifier"}],"roleHeading":"Type Alias","navigatorTitle":[{"kind":"identifier","text":"SyntaxNodePath"}],"symbolKind":"typealias","title":"SyntaxNodePath"},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/Cambium"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SyntaxNodePath","kind":"identifier"},{"text":" = [","kind":"text"},{"text":"UInt32","preciseIdentifier":"s:s6UInt32V","kind":"typeIdentifier"},{"text":"]","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Each index is a position in the parent’s full child list (counting both","type":"text"},{"text":" ","type":"text"},{"text":"nodes and tokens), not the node-only count exposed by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/SyntaxNodeCursor\/childCount"},{"text":". This matches the indexing used by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/SyntaxNodeCursor\/childIndexPath()"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/SyntaxNodeCursor\/withDescendant(atPath:_:)"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This is intent-only documentation: the compiler treats it as","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"[UInt32]"},{"text":", so it does not enforce path-vs-array distinctions. It","type":"text"},{"text":" ","type":"text"},{"text":"exists to make API signatures readable and to leave room for a wrapper","type":"text"},{"text":" ","type":"text"},{"text":"type later.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/SyntaxNodePath"},"variants":[{"paths":["\/documentation\/cambium\/syntaxnodepath"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://org.cambium.Cambium/documentation/Cambium/SyntaxNodePath":{"navigatorTitle":[{"text":"SyntaxNodePath","kind":"identifier"}],"url":"\/documentation\/cambium\/syntaxnodepath","title":"SyntaxNodePath","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/SyntaxNodePath","kind":"symbol","type":"topic","abstract":[{"text":"A path from a green tree’s root to a descendant node, expressed as the","type":"text"},{"text":" ","type":"text"},{"text":"sequence of green child-slot indices (one index per descent step).","type":"text"}],"role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SyntaxNodePath","kind":"identifier"}]},"https://github.com/domenicquirl/cstree":{"type":"link","url":"https:\/\/github.com\/domenicquirl\/cstree","title":"cstree","titleInlineContent":[{"code":"cstree","type":"codeVoice"}],"identifier":"https:\/\/github.com\/domenicquirl\/cstree"},"doc://org.cambium.Cambium/documentation/Cambium":{"type":"topic","title":"Cambium","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"A Swift-native concrete syntax tree library inspired by Rust’s"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/domenicquirl\/cstree"},{"text":".","type":"text"}],"url":"\/documentation\/cambium","identifier":"doc:\/\/org.cambium.Cambium