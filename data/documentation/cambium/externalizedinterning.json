e correctness"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/GreenNodeCache"},{"text":" keys node storage by raw","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenKey"},{"text":" values. ","type":"text"},{"inlineContent":[{"type":"text","text":"Mixing a cache populated under one"},{"type":"text","text":" "},{"type":"text","text":"interner’s namespace with another interner silently corrupts text"},{"type":"text","text":" "},{"type":"text","text":"resolution and defeats green-node identity"}],"type":"strong"},{"text":" as the “same subtree”","type":"text"},{"text":" ","type":"text"},{"text":"signal. ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/GreenTreeContext"},{"text":" makes the pairing structural:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The public "},{"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/GreenTreeContext\/init(interner:policy:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"always pairs an interner with a fresh cache."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The convenience "},{"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/GreenTreeContext\/init(policy:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"mints both halves together."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The only way to forward state across builds is"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/GreenBuildResult\/intoContext()","isActive":true},