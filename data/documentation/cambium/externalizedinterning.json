{"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambium\/externalizedinterning"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/ExternalizedInterning"},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"role":"collectionGroup","modules":[{"name":"Cambium"}],"title":"Externalized Interning"},"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/Cambium"],["doc:\/\/org.cambium.Cambium\/documentation\/Cambium","doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/CalculatorExample"]]},"abstract":[{"text":"Plug an external token-text store into Cambium via the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/TokenInterner"},{"text":" protocol.","type":"text"}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Cambium’s green-node cache and token interner are independent components.","type":"text"},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/GreenTreeContext"},{"text":" bundles them as a namespace-bound","type":"text"},{"text":" ","type":"text"},{"text":"unit, but only the ","type":"text"},{"type":"strong","inlineContent":[{"text":"interner","type":"text"}]},{"text":" is intended to be externalized: it","type":"text"},{"text":" ","type":"text"},{"text":"controls token-text vocabulary, namespace identity, and the resolver","type":"text"},{"text":" ","type":"text"},{"text":"attached to every finished tree. The cache stays internal-but-tunable","type":"text"},{"text":" ","type":"text"},{"text":"via ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/GreenCachePolicy"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The protocol shape:","type":"text"}]},{"type":"codeListing","code":["public protocol TokenInterner: AnyObject {","    var namespace: TokenKeyNamespace { get }","    func intern(_ bytes: UnsafeBufferPointer<UInt8>) throws -> TokenKey","    func storeLargeText(_ text: String) -> LargeTokenTextID","    func makeResolver() -> any TokenResolver","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"TokenInterner"},{"text":" deliberately does ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"text":" refine ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/TokenResolver"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Inheritance would force every conformer to be ","type":"text"},{"type":"codeVoice","code":"Sendable"},{"text":", which would","type":"text"},{"text":" ","type":"text"},{"text":"silently expose single-owner mutable stores as if they were thread-safe.","type":"text"},{"text":" ","type":"text"},{"text":"By keeping the protocols disjoint:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"CambiumBuilder\/LocalTokenInterner"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"TokenInterner"},{"text":" only — its","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/LocalTokenInterner\/makeResolver()"},{"text":" returns a frozen","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/TokenTextSnapshot"},{"text":", and the interner itself cannot be","type":"text"},{"text":" ","type":"text"},{"text":"passed where a resolver is expected.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"CambiumBuilder\/SharedTokenInterner"},{"text":" conforms to both protocols","type":"text"},{"text":" ","type":"text"},{"text":"separately because it really is thread-safe; its ","type":"text"},{"type":"codeVoice","code":"makeResolver()"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"type":"codeVoice","code":"self"},{"text":" (a live resolver).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A custom backend (e.g., a query-store-backed interner) opts into","type":"text"},{"text":" ","type":"text"},{"text":"whichever protocols its semantics actually support.","type":"text"}],"type":"paragraph"}]}]},{"text":"Two built-in backends","type":"heading","anchor":"Two-built-in-backends","level":2},{"type":"paragraph","inlineContent":[{"text":"For most builds, ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/GreenTreeContext\/init(policy:)"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"sufficient — it mints a fresh ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/LocalTokenInterner"},{"text":" ","type":"text"},{"text":"internally. Reach for the externalized API when you have one of these","type":"text"},{"text":" ","type":"text"},{"text":"needs:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Parallel parsing."}]},{"text":" N workers each parse an independent subtree of one","type":"text"},{"text":" ","type":"text"},{"text":"logical CST. Without a shared interner, every worker mints its own","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/TokenKey"},{"text":"s, and merging via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/GreenTreeBuilder\/reuseSubtree(_:)"},{"text":" falls into","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/SubtreeReuseOutcome\/remapped"},{"text":" — re-interning every","type":"text"},{"text":" ","type":"text"},{"text":"dynamic token. With a shared ","type":"text"},{"code":"CambiumBuilder\/SharedTokenInterner","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"every reuse takes the "},{"code":"CambiumBuilder\/SubtreeReuseOutcome\/direct","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"fast path:"}]},{"syntax":"swift","code":["let interner = SharedTokenInterner()","","await withThrowingTaskGroup(of: SyntaxTree<MyLang>.self) { group in","    for source in inputs {","        group.addTask {","            let context = GreenTreeContext<MyLang>(","                interner: interner,","                policy: .documentLocal","            )","            let builder = GreenTreeBuilder<MyLang>(context: consume context)","            \/\/ ... drive parsing ...","            return try parser.finish().tree","        }","    }","    \/\/ Splice each worker tree into a master builder also bound to","    \/\/ `interner` — `reuseSubtree` returns `.direct` every time.","}"],"type":"codeListing"},{"inlineContent":[{"text":"The Calculator example’s ","type":"text"},{"type":"codeVoice","code":"parseCalculatorExpressionsInParallel(_:interner:)"},{"text":" ","type":"text"},{"text":"demonstrates the full pattern end-to-end.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Long-lived editor sessions.","type":"text"}],"type":"strong"},{"type":"text","text":" A single "},{"code":"CambiumBuilder\/SharedTokenInterner","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"shared across every reparse means token vocabulary survives indefinitely;"},{"type":"text","text":" "},{"text":"every ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/GreenTreeContext"},{"text":" minted from","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumBuilder\/GreenBuildResult\/intoContext()"},{"text":" keeps the same","type":"text"},{"text":" ","type":"text"},{"text":"namespace, so cross-edit identity-preserving subtree reuse keeps working","type":"text"},{"text":" ","type":"text"},{"text":"across the entire session.","type":"text"}],"type":"paragraph"},{"text":"Backing an interner with a query store","level":2,"anchor":"Backing-an-interner-with-a-query-store","type":"heading"},{"inlineContent":[{"text":"The protocol is small enough to wrap an arbitrary external store. The","type":"text"},{"text":" ","type":"text"},{"text":"pattern is:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Define a class that conforms to ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/TokenInterner"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Mint a single ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/TokenKeyNamespace"},{"text":" instance per backing","type":"text"},{"text":" ","type":"text"},{"text":"store; expose it via the ","type":"text"},{"type":"codeVoice","code":"namespace"},{"text":" property. The key namespace is","type":"text"},{"text":" ","type":"text"},{"text":"tied to the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"store"}]},{"type":"text","text":" identity, not the wrapper instance — multiple"},{"type":"text","text":" "},{"type":"text","text":"wrapper instances against the same store should expose the same"},{"text":" ","type":"text"},{"type":"text","text":"namespace, and a wrapper around a different store gets a different"},{"text":" ","type":"text"},{"text":"namespace.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"type":"codeVoice","code":"intern(_ bytes:)"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"storeLargeText(_:)"},{"text":" by delegating","type":"text"},{"text":" ","type":"text"},{"text":"to the store. Internal id formats (","type":"text"},{"type":"codeVoice","code":"UInt32"},{"text":" indices, hashed handles,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GUIDs converted to a "},{"type":"codeVoice","code":"UInt32"},{"type":"text","text":" via your own scheme) all work as long"},{"text":" ","type":"text"},{"type":"text","text":"as round-tripping is stable."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Pick ","type":"text"},{"code":"makeResolver()","type":"codeVoice"},{"text":"’s policy:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"For a thread-safe live store, also conform to ","type":"text"},{"code":"CambiumCore\/TokenResolver","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and return ","type":"text"},{"code":"self","type":"codeVoice"},{"text":" — finished trees see the live store.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"For a snapshot-only model, return a frozen","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/TokenTextSnapshot"},{"text":" capturing only the keys this","type":"text"},{"text":" ","type":"text"},{"text":"tree’s ","type":"text"},{"type":"codeVoice","code":"finish()"},{"text":" referenced, so the tree is decoupled from","type":"text"},{"text":" ","type":"text"},{"text":"subsequent store mutations.","type":"text"}],"type":"paragraph"}]}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"Sketch:"}],"type":"paragraph"},{"code":["public final class DatabaseTokenInterner<DB: SomeQueryDatabase>:","    TokenInterner, TokenResolver, @unchecked Sendable","{","    public let namespace: TokenKeyNamespace","    public var tokenKeyNamespace: TokenKeyNamespace? { namespace }","","    private let db: DB","","    public init(_ db: DB, namespace: TokenKeyNamespace) {","        self.db = db","        self.namespace = namespace","    }","","    public func intern(_ bytes: UnsafeBufferPointer<UInt8>) throws -> TokenKey {","        \/\/ Forward to the store; convert its returned id to TokenKey.","        try db.intern(bytes)","    }","","    public func storeLargeText(_ text: String) -> LargeTokenTextID {","        db.storeLargeText(text)","    }","","    public func resolve(_ key: TokenKey) -> String {","        db.text(for: key)","    }","","    public func withUTF8<R>(","        _ key: TokenKey,","        _ body: (UnsafeBufferPointer<UInt8>) throws -> R","    ) rethrows -> R {","        try db.withTextUTF8(key, body)","    }","","    public func makeResolver() -> any TokenResolver { self }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This is the same shape Rust’s "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/domenicquirl\/cstree"},{"type":"text","text":" "},{"type":"text","text":"uses to plug in"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/salsa-rs\/salsa"},{"type":"text","text":" as a backing store: "},{"code":"cstree","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"defines an "},{"code":"Interner","type":"codeVoice"},{"type":"text","text":" trait, salsa users wrap their database to satisfy"},{"type":"text","text":" "},{"type":"text","text":"it. Cambium’s protocol is the Swift translation; the integration is"},{"type":"text","text":" "},{"type":"text","text":"purely conceptual (no direct dependency)."}],"type":"paragraph"},{"text":"Namespace correctness","level":2,"anchor":"Namespace-correctness","type":"heading"},{"inlineContent":[{"code":"CambiumBuilder\/GreenNodeCache","type":"codeVoice"},{"type":"text","text":" keys node storage by raw"},{"type":"text","text":" "},{"code":"CambiumCore\/TokenKey","type":"codeVoice"},{"type":"text","text":" values. "},{"type":"strong","inlineContent":[{"text":"Mixing a cache populated under one","type":"text"},{"text":" ","type":"text"},{"text":"interner’s namespace with another interner silently corrupts text","type":"text"},{"text":" ","type":"text"},{"text":"resolution and defeats green-node identity","type":"text"}]},{"type":"text","text":" as the “same subtree”"},{"type":"text","text":" "},{"type":"text","text":"signal. "},{"code":"CambiumBuilder\/GreenTreeContext","type":"codeVoice"},{"type":"text","text":" makes the pairing structural:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The public "},{"code":"CambiumBuilder\/GreenTreeContext\/init(interner:policy:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"always pairs an interner with a fresh cache."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The convenience "},{"code":"CambiumBuilder\/GreenTreeContext\/init(policy:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"mints both halves together."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The only way to forward state across builds is"},{"type":"text","text":" "},{"code":"CambiumBuilder\/GreenBuildResult\/intoContext()","type":"codeVoice"},{"type":"text","text":", which carries the"},{"type":"text","text":" "},{"type":"text","text":"prior context’s "},{"code":"(interner, cache)","type":"codeVoice"},{"type":"text","text":" pair as a unit."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"There is no public path to construct a context from a freely-chosen"},{"type":"text","text":" "},{"code":"(interner, cache)","type":"codeVoice"},{"type":"text","text":" pair — that would reintroduce the silent corruption"},{"type":"text","text":" "},{"type":"text","text":"hazard."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.cambium.Cambium/documentation/Cambium":{"url":"\/documentation\/cambium","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium","type":"topic","abstract":[{"text":"A Swift-native concrete syntax tree library inspired by Rust’s","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/domenicquirl\/cstree","isActive":true},{"text":".","type":"text"}],"title":"Cambium","kind":"symbol","role":"collection"},"https://github.com/domenicquirl/cstree":{"identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"link","title":"cstree","titleInlineContent":[{"code":"cstree","type":"codeVoice"}],"url":"https:\/\/github.com\/domenicquirl\/cstree"},"doc://org.cambium.Cambium/documentation/Cambium/CalculatorExample":{"kind":"article","role":"sampleCode","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/CalculatorExample","type":"topic","abstract":[{"type":"text","text":"A complete end-to-end example using Cambium to parse, traverse, edit,"},{"type":"text","text":" "},{"type":"text","text":"and evaluate a small arithmetic language."}],"title":"Calculator","url":"\/documentation\/cambium\/calculatorexample"},"https://github.com/salsa-rs/salsa":{"identifier":"https:\/\/github.com\/salsa-rs\/salsa","type":"link","title":"salsa","titleInlineContent":[{"code":"salsa","type":"codeVoice"}],"url":"https:\/\/github.com\/salsa-rs\/salsa"}}}