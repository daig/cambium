{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/ExternalizedInterning"},"kind":"article","hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/Cambium"],["doc:\/\/org.cambium.Cambium\/documentation\/Cambium","doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/CalculatorExample"]]},"metadata":{"modules":[{"name":"Cambium"}],"title":"Externalized Interning","role":"collectionGroup"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Cambium’s green-node cache and token interner are independent components."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"codeVoice","code":"CambiumBuilder\/GreenTreeContext"},{"type":"text","text":" bundles them as a namespace-bound"},{"type":"text","text":" "},{"type":"text","text":"unit, but only the "},{"type":"strong","inlineContent":[{"type":"text","text":"interner"}]},{"type":"text","text":" is intended to be externalized: it"},{"type":"text","text":" "},{"type":"text","text":"controls token-text vocabulary, namespace identity, and the resolver"},{"type":"text","text":" "},{"type":"text","text":"attached to every finished tree. The cache stays internal-but-tunable"},{"type":"text","text":" "},{"type":"text","text":"via "},{"type":"codeVoice","code":"CambiumBuilder\/GreenCachePolicy"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The protocol shape:"}],"type":"paragraph"},{"syntax":"swift","code":["public protocol TokenInterner: AnyObject {","    var namespace: TokenKeyNamespace { get }","    func intern(_ bytes: UnsafeBufferPointer<UInt8>) throws -> TokenKey","    func storeLargeText(_ text: String) -> LargeTokenTextID","    func makeResolver() -> any TokenResolver","}"],"type":"codeListing"},{"inlineContent":[{"code":"TokenInterner","type":"codeVoice"},{"type":"text","text":" deliberately does "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" refine "},{"code":"CambiumCore\/TokenResolver","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inheritance would force every conformer to be "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", which would"},{"type":"text","text":" "},{"type":"text","text":"silently expose single-owner mutable stores as if they were thread-safe."},{"type":"text","text":" "},{"type":"text","text":"By keeping the protocols disjoint:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CambiumBuilder\/LocalTokenInterner"},{"type":"text","text":" is "},{"type":"codeVoice","code":"TokenInterner"},{"type":"text","text":" only — its"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumBuilder\/LocalTokenInterner\/makeResolver()"},{"type":"text","text":" returns a frozen"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/TokenTextSnapshot"},{"type":"text","text":", and the interner itself cannot be"},{"type":"text","text":" "},{"type":"text","text":"passed where a resolver is expected."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CambiumBuilder\/SharedTokenInterner"},{"type":"text","text":" conforms to both protocols"},{"type":"text","text":" "},{"type":"text","text":"separately because it really is thread-safe; its "},{"type":"codeVoice","code":"makeResolver()"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"self"},{"type":"text","text":" (a live resolver)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A custom backend (e.g., a query-store-backed interner) opts into"},{"type":"text","text":" "},{"type":"text","text":"whichever protocols its semantics actually support."}]}]}],"type":"unorderedList"},{"text":"Two built-in backends","level":2,"anchor":"Two-built-in-backends","type":"heading"},{"inlineContent":[{"type":"text","text":"For most builds, "},{"code":"CambiumBuilder\/GreenTreeContext\/init(policy:)","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"sufficient — it mints a fresh "},{"code":"CambiumBuilder\/LocalTokenInterner","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"internally. Reach for the externalized API when you have one of these"},{"type":"text","text":" "},{"type":"text","text":"needs:"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Parallel parsing.","type":"text"}]},{"type":"text","text":" N workers each parse an independent subtree of one"},{"type":"text","text":" "},{"type":"text","text":"logical CST. Without a shared interner, every worker mints its own"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/TokenKey"},{"text":"s, and merging via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/GreenTreeBuilder\/reuseSubtree(_:)"},{"text":" falls into","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/SubtreeReuseOutcome\/remapped"},{"text":" — re-interning every","type":"text"},{"text":" ","type":"text"},{"text":"dynamic token. With a shared ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/SharedTokenInterner"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"every reuse takes the ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/SubtreeReuseOutcome\/direct"},{"text":" ","type":"text"},{"text":"fast path:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let interner = SharedTokenInterner()","","await withThrowingTaskGroup(of: SyntaxTree<MyLang>.self) { group in","    for source in inputs {","        group.addTask {","            let context = GreenTreeContext<MyLang>(","                interner: interner,","                policy: .documentLocal","            )","            let builder = GreenTreeBuilder<MyLang>(context: consume context)","            \/\/ ... drive parsing ...","            return try parser.finish().tree","        }","    }","    \/\/ Splice each worker tree into a master builder also bound to","    \/\/ `interner` — `reuseSubtree` returns `.direct` every time.","}"],"type":"codeListing"},{"inlineContent":[{"text":"The Calculator example’s ","type":"text"},{"type":"codeVoice","code":"parseCalculatorExpressionsInParallel(_:interner:)"},{"text":" ","type":"text"},{"text":"demonstrates the full pattern end-to-end.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Long-lived editor sessions.","type":"text"}]},{"text":" A single ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/SharedTokenInterner"},{"text":" ","type":"text"},{"text":"shared across every reparse means token vocabulary survives indefinitely;","type":"text"},{"text":" ","type":"text"},{"text":"every ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/GreenTreeContext"},{"text":" minted from","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumBuilder\/GreenBuildResult\/intoContext()"},{"text":" keeps the same","type":"text"},{"text":" ","type":"text"},{"text":"namespace, so cross-edit identity-preserving subtree reuse keeps working","type":"text"},{"text":" ","type":"text"},{"text":"across the entire session.","type":"text"}],"type":"paragraph"},{"text":"Backing an interner with a query store","level":2,"anchor":"Backing-an-interner-with-a-query-store","type":"heading"},{"inlineContent":[{"text":"The protocol is small enough to wrap an arbitrary external store. The","type":"text"},{"text":" ","type":"text"},{"text":"pattern is:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Define a class that conforms to "},{"code":"CambiumCore\/TokenInterner","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mint a single "},{"code":"CambiumCore\/TokenKeyNamespace","type":"codeVoice"},{"type":"text","text":" instance per backing"},{"type":"text","text":" "},{"type":"text","text":"store; expose it via the "},{"code":"namespace","type":"codeVoice"},{"type":"text","text":" property. The key namespace is"},{"type":"text","text":" "},{"type":"text","text":"tied to the "},{"type":"strong","inlineContent":[{"text":"store","type":"text"}]},{"type":"text","text":" identity, not the wrapper instance — multiple"},{"type":"text","text":" "},{"type":"text","text":"wrapper instances against the same store should expose the same"},{"type":"text","text":" "},{"type":"text","text":"namespace, and a wrapper around a different store gets a different"},{"type":"text","text":" "},{"type":"text","text":"namespace."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"type":"codeVoice","code":"intern(_ bytes:)"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"storeLargeText(_:)"},{"text":" by delegating","type":"text"},{"text":" ","type":"text"},{"text":"to the store. Internal id formats (","type":"text"},{"type":"codeVoice","code":"UInt32"},{"text":" indices, hashed handles,","type":"text"},{"text":" ","type":"text"},{"text":"GUIDs converted to a ","type":"text"},{"type":"codeVoice","code":"UInt32"},{"text":" via your own scheme) all work as long","type":"text"},{"text":" ","type":"text"},{"text":"as round-tripping is stable.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Pick ","type":"text"},{"type":"codeVoice","code":"makeResolver()"},{"text":"’s policy:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"For a thread-safe live store, also conform to ","type":"text"},{"code":"CambiumCore\/TokenResolver","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and return ","type":"text"},{"code":"self","type":"codeVoice"},{"text":" — finished trees see the live store.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For a snapshot-only model, return a frozen","type":"text"},{"text":" ","type":"text"},{"code":"CambiumCore\/TokenTextSnapshot","type":"codeVoice"},{"text":" capturing only the keys this","type":"text"},{"text":" ","type":"text"},{"text":"tree’s ","type":"text"},{"code":"finish()","type":"codeVoice"},{"text":" referenced, so the tree is decoupled from","type":"text"},{"text":" ","type":"text"},{"text":"subsequent store mutations.","type":"text"}]}]}]}]}],"type":"orderedList"},{"inlineContent":[{"text":"Sketch:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["public final class DatabaseTokenInterner<DB: SomeQueryDatabase>:","    TokenInterner, TokenResolver, @unchecked Sendable","{","    public let namespace: TokenKeyNamespace","    public var tokenKeyNamespace: TokenKeyNamespace? { namespace }","","    private let db: DB","","    public init(_ db: DB, namespace: TokenKeyNamespace) {","        self.db = db","        self.namespace = namespace","    }","","    public func intern(_ bytes: UnsafeBufferPointer<UInt8>) throws -> TokenKey {","        \/\/ Forward to the store; convert its returned id to TokenKey.","        try db.intern(bytes)","    }","","    public func storeLargeText(_ text: String) -> LargeTokenTextID {","        db.storeLargeText(text)","    }","","    public func resolve(_ key: TokenKey) -> String {","        db.text(for: key)","    }","","    public func withUTF8<R>(","        _ key: TokenKey,","        _ body: (UnsafeBufferPointer<UInt8>) throws -> R","    ) rethrows -> R {","        try db.withTextUTF8(key, body)","    }","","    public func makeResolver() -> any TokenResolver { self }","}"],"type":"codeListing"},{"inlineContent":[{"text":"This is the same shape Rust’s ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"reference"},{"text":" ","type":"text"},{"text":"uses to plug in","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/salsa-rs\/salsa","type":"reference"},{"text":" as a backing store: ","type":"text"},{"code":"cstree","type":"codeVoice"},{"text":" ","type":"text"},{"text":"defines an ","type":"text"},{"code":"Interner","type":"codeVoice"},{"text":" trait, salsa users wrap their database to satisfy","type":"text"},{"text":" ","type":"text"},{"text":"it. Cambium’s protocol is the Swift translation; the integration is","type":"text"},{"text":" ","type":"text"},{"text":"purely conceptual (no direct dependency).","type":"text"}],"type":"paragraph"},{"text":"Namespace correctness","level":2,"anchor":"Namespace-correctness","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"CambiumBuilder\/GreenNodeCache"},{"type":"text","text":" keys node storage by raw"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/TokenKey"},{"type":"text","text":" values. "},{"type":"strong","inlineContent":[{"text":"Mixing a cache populated under one","type":"text"},{"text":" ","type":"text"},{"text":"interner’s namespace with another interner silently corrupts text","type":"text"},{"text":" ","type":"text"},{"text":"resolution and defeats green-node identity","type":"text"}]},{"type":"text","text":" as the “same subtree”"},{"type":"text","text":" "},{"type":"text","text":"signal. "},{"type":"codeVoice","code":"CambiumBuilder\/GreenTreeContext"},{"type":"text","text":" makes the pairing structural:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The public "},{"code":"CambiumBuilder\/GreenTreeContext\/init(interner:policy:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"always pairs an interner with a fresh cache."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The convenience "},{"code":"CambiumBuilder\/GreenTreeContext\/init(policy:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"mints both halves together."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The only way to forward state across builds is"},{"type":"text","text":" "},{"code":"CambiumBuilder\/GreenBuildResult\/intoContext()","type":"codeVoice"},{"type":"text","text":", which carries the"},{"type":"text","text":" "},{"type":"text","text":"prior context’s "},{"code":"(interner, cache)","type":"codeVoice"},{"type":"text","text":" pair as a unit."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"There is no public path to construct a context from a freely-chosen"},{"type":"text","text":" "},{"type":"codeVoice","code":"(interner, cache)"},{"type":"text","text":" pair — that would reintroduce the silent corruption"},{"type":"text","text":" "},{"type":"text","text":"hazard."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/cambium\/externalizedinterning"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Plug an external token-text store into Cambium via the","type":"text"},{"text":" ","type":"text"},{"code":"CambiumCore\/TokenInterner","type":"codeVoice"},{"text":" protocol.","type":"text"}],"sections":[],"references":{"https://github.com/salsa-rs/salsa":{"titleInlineContent":[{"type":"codeVoice","code":"salsa"}],"url":"https:\/\/github.com\/salsa-rs\/salsa","identifier":"https:\/\/github.com\/salsa-rs\/salsa","type":"link","title":"salsa"},"doc://org.cambium.Cambium/documentation/Cambium":{"type":"topic","title":"Cambium","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"A Swift-native concrete syntax tree library inspired by Rust’s"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/domenicquirl\/cstree"},{"text":".","type":"text"}],"url":"\/documentation\/cambium","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium"},"doc://org.cambium.Cambium/documentation/Cambium/CalculatorExample":{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/CalculatorExample","type":"topic","title":"Calculator","kind":"article","url":"\/documentation\/cambium\/calculatorexample","abstract":[{"text":"A complete end-to-end example using Cambium to parse, traverse, edit,","type":"text"},{"text":" ","type":"text"},{"text":"and evaluate a small arithmetic language.","type":"text"}],"role":"sampleCode"},"https://github.com/domenicquirl/cstree":{"titleInlineContent":[{"type":"codeVoice","code":"cstree"}],"url":"https:\/\/github.com\/domenicquirl\/cstree","identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"link","title":"cstree"}}}