{"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/Cambium"],["doc:\/\/org.cambium.Cambium\/documentation\/Cambium","doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/CalculatorExample"]]},"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Cambium’s green-node cache and token interner are independent components.","type":"text"},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"code":"CambiumBuilder\/GreenTreeContext","type":"codeVoice"},{"text":" bundles them as a namespace-bound","type":"text"},{"text":" ","type":"text"},{"text":"unit, but only the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"interner"}]},{"text":" is intended to be externalized: it","type":"text"},{"text":" ","type":"text"},{"text":"controls token-text vocabulary, namespace identity, and the resolver","type":"text"},{"text":" ","type":"text"},{"text":"attached to every finished tree. The cache stays internal-but-tunable","type":"text"},{"text":" ","type":"text"},{"text":"via ","type":"text"},{"code":"CambiumBuilder\/GreenCachePolicy","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The protocol shape:","type":"text"}]},{"type":"codeListing","code":["public protocol TokenInterner: AnyObject {","    var namespace: TokenKeyNamespace { get }","    func intern(_ bytes: UnsafeBufferPointer<UInt8>) throws -> TokenKey","    func storeLargeText(_ text: String) -> LargeTokenTextID","    func makeResolver() -> any TokenResolver","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"code":"TokenInterner","type":"codeVoice"},{"text":" deliberately does ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"text":" refine ","type":"text"},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenResolver","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Inheritance would force every conformer to be ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", which would","type":"text"},{"text":" ","type":"text"},{"text":"silently expose single-owner mutable stores as if they were thread-safe.","type":"text"},{"text":" ","type":"text"},{"text":"By keeping the protocols disjoint:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CambiumBuilder\/LocalTokenInterner"},{"type":"text","text":" is "},{"type":"codeVoice","code":"TokenInterner"},{"type":"text","text":" only — its"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumBuilder\/LocalTokenInterner\/makeResolver()"},{"type":"text","text":" returns a frozen"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenTextSnapshot","type":"reference","isActive":true},{"type":"text","text":", and the interner itself cannot be"},{"type":"text","text":" "},{"type":"text","text":"passed where a resolver is expected."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CambiumBuilder\/SharedTokenInterner"},{"type":"text","text":" conforms to both protocols"},{"type":"text","text":" "},{"type":"text","text":"separately because it really is thread-safe; its "},{"type":"codeVoice","code":"makeResolver()"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"self"},{"type":"text","text":" (a live resolver)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A custom backend (e.g., a query-store-backed interner) opts into"},{"type":"text","text":" "},{"type":"text","text":"whichever protocols its semantics actually support."}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Two built-in backends","anchor":"Two-built-in-backends"},{"type":"paragraph","inlineContent":[{"text":"For most builds, ","type":"text"},{"code":"CambiumBuilder\/GreenTreeContext\/init(policy:)","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"sufficient — it mints a fresh ","type":"text"},{"code":"CambiumBuilder\/LocalTokenInterner","type":"codeVoice"},{"text":" ","type":"text"},{"text":"internally. Reach for the externalized API when you have one of these","type":"text"},{"text":" ","type":"text"},{"text":"needs:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Parallel parsing."}]},{"text":" N workers each parse an independent subtree of one","type":"text"},{"text":" ","type":"text"},{"text":"logical CST. Without a shared interner, every worker mints its own","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenKey","type":"reference","isActive":true},{"text":"s, and merging via","type":"text"},{"text":" ","type":"text"},{"code":"CambiumBuilder\/GreenTreeBuilder\/reuseSubtree(_:)","type":"codeVoice"},{"text":" falls into","type":"text"},{"text":" ","type":"text"},{"code":"CambiumBuilder\/SubtreeReuseOutcome\/remapped","type":"codeVoice"},{"text":" — re-interning every","type":"text"},{"text":" ","type":"text"},{"text":"dynamic token. With a shared ","type":"text"},{"code":"CambiumBuilder\/SharedTokenInterner","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"every reuse takes the ","type":"text"},{"code":"CambiumBuilder\/SubtreeReuseOutcome\/direct","type":"codeVoice"},{"text":" ","type":"text"},{"text":"fast path:","type":"text"}]},{"type":"codeListing","code":["let interner = SharedTokenInterner()","","await withThrowingTaskGroup(of: SyntaxTree<MyLang>.self) { group in","    for source in inputs {","        group.addTask {","            let context = GreenTreeContext<MyLang>(","                interner: interner,","                policy: .documentLocal","            )","            let builder = GreenTreeBuilder<MyLang>(context: consume context)","            \/\/ ... drive parsing ...","            return try parser.finish().tree","        }","    }","    \/\/ Splice each worker tree into a master builder also bound to","    \/\/ `interner` — `reuseSubtree` returns `.direct` every time.","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The Calculator example’s ","type":"text"},{"code":"parseCalculatorExpressionsInParallel(_:interner:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"demonstrates the full pattern end-to-end.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Long-lived editor sessions."}]},{"text":" A single ","type":"text"},{"code":"CambiumBuilder\/SharedTokenInterner","type":"codeVoice"},{"text":" ","type":"text"},{"text":"shared across every reparse means token vocabulary survives indefinitely;","type":"text"},{"text":" ","type":"text"},{"text":"every ","type":"text"},{"code":"CambiumBuilder\/GreenTreeContext","type":"codeVoice"},{"text":" minted from","type":"text"},{"text":" ","type":"text"},{"code":"CambiumBuilder\/GreenBuildResult\/intoContext()","type":"codeVoice"},{"text":" keeps the same","type":"text"},{"text":" ","type":"text"},{"text":"namespace, so cross-edit identity-preserving subtree reuse keeps working","type":"text"},{"text":" ","type":"text"},{"text":"across the entire session.","type":"text"}]},{"type":"heading","level":2,"text":"Backing an interner with a query store","anchor":"Backing-an-interner-with-a-query-store"},{"type":"paragraph","inlineContent":[{"text":"The protocol is small enough to wrap an arbitrary external store. The","type":"text"},{"text":" ","type":"text"},{"text":"pattern is:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Define a class that conforms to "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenInterner","type":"reference","isActive":true},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mint a single "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenKeyNamespace","type":"reference","isActive":true},{"type":"text","text":" instance per backing"},{"type":"text","text":" "},{"type":"text","text":"store; expose it via the "},{"type":"codeVoice","code":"namespace"},{"type":"text","text":" property. The key namespace is"},{"type":"text","text":" "},{"type":"text","text":"tied to the "},{"inlineContent":[{"type":"text","text":"store"}],"type":"strong"},{"type":"text","text":" identity, not the wrapper instance — multiple"},{"type":"text","text":" "},{"type":"text","text":"wrapper instances against the same store should expose the same"},{"type":"text","text":" "},{"type":"text","text":"namespace, and a wrapper around a different store gets a different"},{"type":"text","text":" "},{"type":"text","text":"namespace."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"code":"intern(_ bytes:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"storeLargeText(_:)","type":"codeVoice"},{"text":" by delegating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the store. Internal id formats ("},{"code":"UInt32","type":"codeVoice"},{"text":" indices, hashed handles,","type":"text"},{"type":"text","text":" "},{"text":"GUIDs converted to a ","type":"text"},{"code":"UInt32","type":"codeVoice"},{"text":" via your own scheme) all work as long","type":"text"},{"text":" ","type":"text"},{"text":"as round-tripping is stable.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Pick ","type":"text"},{"type":"codeVoice","code":"makeResolver()"},{"text":"’s policy:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"For a thread-safe live store, also conform to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenResolver"},{"type":"text","text":" "},{"type":"text","text":"and return "},{"type":"codeVoice","code":"self"},{"type":"text","text":" — finished trees see the live store."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"For a snapshot-only model, return a frozen"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenTextSnapshot"},{"type":"text","text":" capturing only the keys this"},{"type":"text","text":" "},{"type":"text","text":"tree’s "},{"code":"finish()","type":"codeVoice"},{"type":"text","text":" referenced, so the tree is decoupled from"},{"type":"text","text":" "},{"type":"text","text":"subsequent store mutations."}],"type":"paragraph"}]}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"Sketch:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public final class DatabaseTokenInterner<DB: SomeQueryDatabase>:","    TokenInterner, TokenResolver, @unchecked Sendable","{","    public let namespace: TokenKeyNamespace","    public var tokenKeyNamespace: TokenKeyNamespace? { namespace }","","    private let db: DB","","    public init(_ db: DB, namespace: TokenKeyNamespace) {","        self.db = db","        self.namespace = namespace","    }","","    public func intern(_ bytes: UnsafeBufferPointer<UInt8>) throws -> TokenKey {","        \/\/ Forward to the store; convert its returned id to TokenKey.","        try db.intern(bytes)","    }","","    public func storeLargeText(_ text: String) -> LargeTokenTextID {","        db.storeLargeText(text)","    }","","    public func resolve(_ key: TokenKey) -> String {","        db.text(for: key)","    }","","    public func withUTF8<R>(","        _ key: TokenKey,","        _ body: (UnsafeBufferPointer<UInt8>) throws -> R","    ) rethrows -> R {","        try db.withTextUTF8(key, body)","    }","","    public func makeResolver() -> any TokenResolver { self }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the same shape Rust’s "},{"identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"uses to plug in"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/salsa-rs\/salsa","isActive":true},{"type":"text","text":" as a backing store: "},{"code":"cstree","type":"codeVoice"},{"type":"text","text":" "},{"text":"defines an ","type":"text"},{"code":"Interner","type":"codeVoice"},{"type":"text","text":" trait, salsa users wrap their database to satisfy"},{"type":"text","text":" "},{"type":"text","text":"it. Cambium’s protocol is the Swift translation; the integration is"},{"type":"text","text":" "},{"type":"text","text":"purely conceptual (no direct dependency)."}]},{"type":"heading","text":"Namespace correctness","level":2,"anchor":"Namespace-correctness"},{"inlineContent":[{"type":"codeVoice","code":"CambiumBuilder\/GreenNodeCache"},{"type":"text","text":" keys node storage by raw"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenKey"},{"type":"text","text":" values. "},{"type":"strong","inlineContent":[{"text":"Mixing a cache populated under one","type":"text"},{"text":" ","type":"text"},{"text":"interner’s namespace with another interner silently corrupts text","type":"text"},{"text":" ","type":"text"},{"text":"resolution and defeats green-node identity","type":"text"}]},{"type":"text","text":" as the “same subtree”"},{"type":"text","text":" "},{"text":"signal. ","type":"text"},{"code":"CambiumBuilder\/GreenTreeContext","type":"codeVoice"},{"text":" makes the pairing structural:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The public "},{"code":"CambiumBuilder\/GreenTreeContext\/init(interner:policy:)","type":"codeVoice"},{"type":"text","text":" "},{"text":"always pairs an interner with a fresh cache.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The convenience ","type":"text"},{"code":"CambiumBuilder\/GreenTreeContext\/init(policy:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"mints both halves together."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The only way to forward state across builds is"},{"text":" ","type":"text"},{"code":"CambiumBuilder\/GreenBuildResult\/intoContext()","type":"codeVoice"},{"type":"text","text":", which carries the"},{"type":"text","text":" "},{"text":"prior context’s ","type":"text"},{"code":"(interner, cache)","type":"codeVoice"},{"text":" pair as a unit.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"There is no public path to construct a context from a freely-chosen","type":"text"},{"text":" ","type":"text"},{"code":"(interner, cache)","type":"codeVoice"},{"text":" pair — that would reintroduce the silent corruption","type":"text"},{"text":" ","type":"text"},{"text":"hazard.","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.cambium.Cambium\/documentation\/Cambium\/ExternalizedInterning","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambium\/externalizedinterning"]}],"abstract":[{"type":"text","text":"Plug an external token-text store into Cambium via the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenInterner"},{"type":"text","text":" protocol."}],"seeAlsoSections":[{"title":"Building a tree","anchor":"Building-a-tree","generated":true,"identifiers":["doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/TokenInterner"]}],"metadata":{"role":"collectionGroup","roleH