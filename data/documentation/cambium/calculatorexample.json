eContent":[{"type":"codeVoice","code":"CalculatorLexer.swift"},{"type":"text","text":" — token source for the parser."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"CalculatorParser.swift"},{"type":"text","text":" — green-tree construction with checkpoints"},{"type":"text","text":" "},{"type":"text","text":"and error recovery."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"CalculatorTypedAST.swift"},{"type":"text","text":" — typed overlay on top of the CST."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"CalculatorEvaluator.swift"},{"type":"text","text":" — borrowed traversal of the typed AST."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"CalculatorSession.swift"},{"type":"text","text":" — wiring incremental reparse, the analysis"},{"type":"text","text":" "},{"type":"text","text":"cache, and serialization together for the REPL."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"CalculatorFold.swift"},{"type":"text","text":" — replacement witnesses and persistent edits."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"CalculatorParallelEvaluator.swift"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"CalculatorParallelParser.swift"},{"type":"text","text":" — sharing trees across structured"},{"type":"text","text":" "},{"type":"text","text":"concurrency."}],"type":"paragraph"}]}],"type":"orderedList"}]}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"overridingTitle":"View Sample on GitHub","type":"reference","identifier":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator"}},"sections":[],"variants":[{"paths":["\/documentation\/cambium\/calculatorexample"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Sample Code","title":"Calculator","modules":[{"name":"Ca