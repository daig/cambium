at:_:)"},{"type":"text","text":") for left-associative"},{"type":"text","text":" "},{"type":"text","text":"operator precedence, and emits missing\/error nodes for recovery."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"A typed AST overlay.","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"CalculatorTypedAST.swift"},{"type":"text","text":" defines one"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumASTSupport\/TypedSyntaxNode"},{"type":"text","text":" per AST shape and exposes"},{"text":" ","type":"text"},{"type":"text","text":"kind-specific accessors over the generic CST."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Borrowed traversal."}],"type":"strong"},{"text":" ","type":"text"},{"code":"CalculatorEvaluator.swift","type":"codeVoice"},{"text":" walks the typed","type":"text"},{"text":" ","type":"text"},{"text":"AST through borrowed cursors with no per-node allocation.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Owned handles.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"code":"CalculatorParseResult.swift","type":"codeVoice"},{"text":" materializes long-lived","type":"text"},{"text":" ","type":"text"},{"code":"CambiumCore\/SyntaxNodeHandle","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/SyntaxTokenHandle"},{"type":"text","text":" arrays"},{"type":"text","text":" "},{"type":"text","text":"for the "},{"type":"codeVoice","code":":nodes"},{"type":"text","text":" and "},{"type":"codeVoice","code":":tokens"},{"type":"text","text":" REPL commands."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Incremental reparse.","type":"text"}]},{"text":" ","type":"text"},{"type":"codeVoice","code":"CalculatorParser.swift"},{"text":" consults a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumIncremental\/ReuseOracle"},{"text":" to splice unchanged subtrees from the","type":"text"},{"text":" ","type":"text"},{"text":"previous tree; ","type":"text"},{"type":"codeVoice","code":"CalculatorSession.swift"},{"text":" builds a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumIncremental\/ParseWitness"},{"text":" and forwards cached evaluator entries","type":"text"},{"text":" ","type":"text"},{"text":"across edits.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Replacement and witnesses.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"code":"CalculatorFold.swift","type":"codeVoice"},{"text":" constant-folds","type":"text"},{"text":" ","type":"text"},{"text":"one node at a time using ","type":"text"},{"code":"SharedSyntaxTree.replacing(_:with:context:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and classifies references through ","type":"text"},{"code":"CambiumCore\/ReplacementWitness","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Analysis sidecars.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"code":"CalculatorSession.swift","type":"codeVoice"},{"text":" keeps an","type":"text"},{"text":" ","type":"text"},{"code":"CambiumAnalysis\/ExternalAnalysisCache","type":"codeVoice"},{"text":" of evaluated values and a","type":"text"},{"text":" ","type":"text"},{"code":"CambiumAnalysis\/SyntaxMetadataStore","type":"codeVoice"},{"text":" of per-evaluation metadata.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Serialization.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"code":"CalculatorSession.swift","type":"codeVoice"},{"text":" round-trips the current","type":"text"},{"text":" ","type":"text"},{"text":"tree through ","type":"text"},{"code":"CambiumSerialization\/Gre