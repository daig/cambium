{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The Calculator sample is a standalone SwiftPM package that exercises","type":"text"},{"text":" ","type":"text"},{"text":"Cambium’s full public surface against a real grammar. It ships as a","type":"text"},{"text":" ","type":"text"},{"text":"library (","type":"text"},{"type":"codeVoice","code":"CalculatorCore"},{"text":") plus an interactive REPL (","type":"text"},{"type":"codeVoice","code":"calc-repl"},{"text":") so the","type":"text"},{"text":" ","type":"text"},{"text":"same pieces can be unit-tested and poked at by hand.","type":"text"}]},{"style":"tip","name":"Tip","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For a step-by-step walkthrough that builds the calculator one"},{"type":"text","text":" "},{"type":"text","text":"Cambium subsystem at a time, see "},{"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents","isActive":true},{"type":"text","text":". The"},{"type":"text","text":" "},{"type":"text","text":"tutorials use the same source files documented here as their"},{"type":"text","text":" "},{"type":"text","text":"canonical implementation."}]}]},{"type":"paragraph","inlineContent":[{"text":"The grammar covers integer and real literals, parenthesized","type":"text"},{"text":" ","type":"text"},{"text":"sub-expressions, unary minus, the ","type":"text"},{"type":"codeVoice","code":"round(expr)"},{"text":" built-in, and the four","type":"text"},{"text":" ","type":"text"},{"text":"arithmetic operators with normal precedence. The parser preserves input","type":"text"},{"text":" ","type":"text"},{"text":"text losslessly, recovers from malformed input by emitting missing and","type":"text"},{"text":" ","type":"text"},{"text":"error nodes, and only evaluates trees with no parse diagnostics.","type":"text"}]},{"level":2,"anchor":