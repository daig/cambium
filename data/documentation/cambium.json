{"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"anchor":"Essentials","title":"Essentials","identifiers":["doc:\/\/Cambium\/documentation\/Cambium\/GettingStarted"]}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Cambium is a generic library for creating and working with "},{"type":"strong","inlineContent":[{"type":"text","text":"concrete"},{"type":"text","text":" "},{"type":"text","text":"syntax trees"}]},{"type":"text","text":" (CSTs)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"“Traditional” abstract syntax trees (ASTs) usually contain different"},{"type":"text","text":" "},{"type":"text","text":"types of nodes which represent different syntactical elements of the"},{"type":"text","text":" "},{"type":"text","text":"source text of a document and reduce its information to the minimal"},{"type":"text","text":" "},{"type":"text","text":"amount necessary to correctly interpret it. In contrast, CSTs are"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"lossless"}]},{"type":"text","text":" representations of the entire input where all tree nodes"},{"type":"text","text":" "},{"type":"text","text":"are represented homogeneously (the nodes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"untyped"}]},{"type":"text","text":") but tagged"},{"type":"text","text":" "},{"type":"text","text":"with a "},{"type":"codeVoice","code":"CambiumCore\/RawSyntaxKind"},{"type":"text","text":" to determine the kind of grammatical element"},{"type":"text","text":" "},{"type":"text","text":"they represent."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"One big advantage of this representation is that it can recreate the"},{"type":"text","text":" "},{"type":"text","text":"original source exactly while also lending itself very well to the"},{"type":"text","text":" "},{"type":"text","text":"representation of "},{"type":"emphasis","inlineContent":[{"type":"text","text":"incomplete or erroneous"}]},{"type":"text","text":" trees and is thus highly"},{"type":"text","text":" "},{"type":"text","text":"suited for usage in contexts such as IDEs or any other application"},{"type":"text","text":" "},{"type":"text","text":"where a user is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"editing"}]},{"type":"text","text":" the source text."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The concept and the data structures for Cambium’s syntax trees are"},{"type":"text","text":" "},{"type":"text","text":"inspired in part by Swift’s"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/apple\/swift\/tree\/5e2c815edfd758f9b1309ce07bfc01c4bc20ec23\/lib\/Syntax","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and by the Rust "},{"type":"reference","identifier":"https:\/\/github.com\/domenicquirl\/cstree","isActive":true},{"type":"text","text":" "},{"type":"text","text":"library, which itself is a fork of"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/rust-analyzer\/rowan\/","isActive":true},{"type":"text","text":" developed by the"},{"type":"text","text":" "},{"type":"text","text":"authors of "},{"type":"reference","identifier":"https:\/\/github.com\/rust-analyzer\/rust-analyzer\/","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"level":3,"text":"Two-layer storage","type":"heading","anchor":"Two-layer-storage"},{"inlineContent":[{"type":"text","text":"Trees consist of two layers:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The inner ","type":"text"},{"inlineContent":[{"text":"green tree","type":"text"}],"type":"strong"},{"text":" contains the actual source text as","type":"text"},{"text":" ","type":"text"},{"text":"position-independent green nodes. Tokens and nodes that appear","type":"text"},{"text":" ","type":"text"},{"text":"identically at multiple places in the source are deduplicated in","type":"text"},{"text":" ","type":"text"},{"text":"this representation in order to store the tree efficiently. This","type":"text"},{"text":" ","type":"text"},{"text":"means that a green tree may structurally be a DAG rather than a","type":"text"},{"text":" ","type":"text"},{"text":"unique object per source position.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"To remedy this, the real syntax tree is constructed on top of the","type":"text"},{"text":" ","type":"text"},{"text":"green tree as a secondary tree (called the ","type":"text"},{"inlineContent":[{"text":"red tree","type":"text"}],"type":"strong"},{"text":") which","type":"text"},{"text":" ","type":"text"},{"text":"models the exact source structure.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"As a possible third layer, a strongly typed AST can be built on top of"},{"type":"text","text":" "},{"type":"text","text":"the red tree (see "},{"type":"reference","identifier":"doc:\/\/Cambium\/documentation\/Cambium\/GettingStarted#AST-Layer","isActive":true},{"type":"text","text":")."}],"type":"paragraph"},{"level":3,"text":"Notable differences from `cstree`","type":"heading","anchor":"Notable-differences-from-cstree"},{"inlineContent":[{"type":"text","text":"Cambium tracks "},{"type":"codeVoice","code":"cstree"},{"type":"text","text":"’s practical guarantees but uses modern Swift"},{"type":"text","text":" "},{"type":"text","text":"language features rather than imitating Rust mechanically:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Borrowed cursors are the primary traversal API.","type":"text"}],"type":"strong"},{"text":" Walking a tree","type":"text"},{"text":" ","type":"text"},{"text":"uses ","type":"text"},{"code":"~Copyable","type":"codeVoice"},{"text":" ","type":"text"},{"code":"CambiumCore\/SyntaxNodeCursor","type":"codeVoice"},{"text":"s borrowed inside a closure","type":"text"},{"text":" ","type":"text"},{"text":"scope. There are no per-node retains during traversal, no implicit","type":"text"},{"text":" ","type":"text"},{"text":"array allocation for child iteration, and no surprise copies of","type":"text"},{"text":" ","type":"text"},{"text":"red node references. Copyable ","type":"text"},{"code":"CambiumCore\/SyntaxNodeHandle","type":"codeVoice"},{"text":"s exist for","type":"text"},{"text":" ","type":"text"},{"text":"long-lived references but are an explicit opt-in.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Move-only builders, caches, and trees.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"code":"CambiumBuilder\/GreenTreeBuilder","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"CambiumBuilder\/GreenNodeCache","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumBuilder\/GreenBuildResult","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"CambiumCore\/SyntaxTree","type":"codeVoice"},{"text":" are all","type":"text"},{"text":" ","type":"text"},{"code":"~Copyable","type":"codeVoice"},{"text":". Ownership boundaries are visible in the type system;","type":"text"},{"text":" ","type":"text"},{"text":"you cannot accidentally clone a builder or duplicate a parse cache.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Synchronous traversal, ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":" snapshots.","type":"text"}],"type":"strong"},{"text":" Tree navigation","type":"text"},{"text":" ","type":"text"},{"text":"never goes through an actor. Once a tree is built it can be","type":"text"},{"text":" ","type":"text"},{"text":"promoted to a ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":" ","type":"text"},{"code":"CambiumCore\/SharedSyntaxTree","type":"codeVoice"},{"text":" with","type":"text"},{"text":" ","type":"text"},{"code":"CambiumCore\/SyntaxTree\/intoShared()","type":"codeVoice"},{"text":" and freely shared across actors and","type":"text"},{"text":" ","type":"text"},{"text":"tasks.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Witness-based change tracking.","type":"text"}],"type":"strong"},{"text":" Editing a tree returns a","type":"text"},{"text":" ","type":"text"},{"code":"CambiumCore\/ReplacementWitness","type":"codeVoice"},{"text":" describing the structural change; an","type":"text"},{"text":" ","type":"text"},{"text":"incremental reparse returns a ","type":"text"},{"code":"CambiumIncremental\/ParseWitness","type":"codeVoice"},{"text":" listing the subtrees","type":"text"},{"text":" ","type":"text"},{"text":"that were carried over by reference. Cambium does not bake an","type":"text"},{"text":" ","type":"text"},{"text":"identity-tracker into the core; consumers translate identities","type":"text"},{"text":" ","type":"text"},{"text":"through witness chains.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"No mutation in place.","type":"text"}],"type":"strong"},{"text":" Trees are persistent. Editing produces a","type":"text"},{"text":" ","type":"text"},{"text":"new tree that shares as much green storage with the old as","type":"text"},{"text":" ","type":"text"},{"text":"possible.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Strict serialization.","type":"text"}],"type":"strong"},{"text":" Snapshots written by","type":"text"},{"text":" ","type":"text"},{"code":"CambiumCore\/SharedSyntaxTree\/serializeGreenSnapshot()","type":"codeVoice"},{"text":" and read by","type":"text"},{"text":" ","type":"text"},{"code":"CambiumSerialization\/GreenSnapshotDecoder","type":"codeVoice"},{"text":" are length-, hash-, and kind-validated at","type":"text"},{"text":" ","type":"text"},{"text":"every record. Bad snapshots are rejected with named errors.","type":"text"}]}]}]},{"level":3,"text":"Modules","type":"heading","anchor":"Modules"},{"inlineContent":[{"type":"text","text":"Cambium is split into several focused modules. Importing the umbrella"},{"type":"text","text":" "},{"type":"codeVoice","code":"Cambium"},{"type":"text","text":" module re-exports the runtime modules; test support and macros"},{"type":"text","text":" "},{"type":"text","text":"are imported explicitly when you need them. You can also pick individual"},{"type":"text","text":" "},{"type":"text","text":"modules directly."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumCore","type":"text"}],"type":"strong"},{"text":" — The foundational layer: ","type":"text"},{"code":"CambiumCore\/RawSyntaxKind","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"CambiumCore\/SyntaxLanguage","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumCore\/TextSize","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumCore\/GreenNode","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumCore\/GreenToken","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"CambiumCore\/SyntaxTree","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumCore\/SyntaxNodeCursor","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumCore\/ReplacementWitness","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumBuilder","type":"text"}],"type":"strong"},{"text":" — ","type":"text"},{"code":"CambiumBuilder\/GreenTreeBuilder","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumBuilder\/GreenNodeCache","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"CambiumBuilder\/LocalTokenInterner","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumBuilder\/SharedTokenInterner","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"SharedSyntaxTree.replacing(_:with:cache:)","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumIncremental","type":"text"}],"type":"strong"},{"text":" — ","type":"text"},{"code":"CambiumIncremental\/ParseInput","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumIncremental\/IncrementalParseSession","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"CambiumIncremental\/ReuseOracle","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumIncremental\/ParseWitness","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumAnalysis","type":"text"}],"type":"strong"},{"text":" — ","type":"text"},{"code":"CambiumAnalysis\/Diagnostic","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumAnalysis\/SyntaxMetadataStore","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"CambiumAnalysis\/ExternalAnalysisCache","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumASTSupport","type":"text"}],"type":"strong"},{"text":" — ","type":"text"},{"code":"CambiumASTSupport\/TypedSyntaxNode","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CambiumASTSupport\/TypedNodeHandle","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumOwnedTraversal","type":"text"}],"type":"strong"},{"text":" — Allocating helpers for handle-based","type":"text"},{"text":" ","type":"text"},{"text":"traversal: ","type":"text"},{"code":"SyntaxNodeHandle.childHandles","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"SyntaxNodeHandle.descendantHandlesPreorder","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumSerialization","type":"text"}],"type":"strong"},{"text":" — ","type":"text"},{"code":"CambiumSerialization\/GreenSnapshotDecoder","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"serializeGreenSnapshot()","type":"codeVoice"},{"text":" extensions.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumTesting","type":"text"}],"type":"strong"},{"text":" — Test-support helpers: ","type":"text"},{"code":"assertRoundTrip(_:equals:)","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"assertTextLength(_:equals:)","type":"codeVoice"},{"text":", ","type":"text"},{"code":"debugTree(_:)","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CambiumSyntaxMacros","type":"text"}],"type":"strong"},{"text":" — ","type":"text"},{"code":"@CambiumSyntaxKind","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"@StaticText","type":"codeVoice"},{"text":" ","type":"text"},{"text":"macros for deriving ","type":"text"},{"code":"CambiumCore\/SyntaxKind","type":"codeVoice"},{"text":" conformance.","type":"text"}]}]}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Cambium\/documentation\/Cambium"},"metadata":{"modules":[{"name":"Cambium"}],"roleHeading":"Framework","externalID":"Cambium","symbolKind":"module","role":"collection","title":"Cambium"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambium"]}],"kind":"symbol","hierarchy":{"paths":[[]]},"sections":[],"abstract":[{"text":"A Swift-native concrete syntax tree library inspired by Rust’s","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/github.com\/domenicquirl\/cstree","isActive":true,"type":"reference"},{"text":".","type":"text"}],"references":{"https://github.com/domenicquirl/cstree":{"url":"https:\/\/github.com\/domenicquirl\/cstree","titleInlineContent":[{"type":"codeVoice","code":"cstree"}],"identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"link","title":"cstree"},"doc://Cambium/documentation/Cambium":{"kind":"symbol","abstract":[{"text":"A Swift-native concrete syntax tree library inspired by Rust’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"reference"},{"text":".","type":"text"}],"title":"Cambium","identifier":"doc:\/\/Cambium\/documentation\/Cambium","url":"\/documentation\/cambium","role":"collection","type":"topic"},"doc://Cambium/documentation/Cambium/GettingStarted#AST-Layer":{"url":"\/documentation\/cambium\/gettingstarted#AST-Layer","abstract":[],"kind":"section","identifier":"doc:\/\/Cambium\/documentation\/Cambium\/GettingStarted#AST-Layer","type":"topic","title":"AST Layer"},"https://github.com/rust-analyzer/rust-analyzer/":{"url":"https:\/\/github.com\/rust-analyzer\/rust-analyzer\/","titleInlineContent":[{"text":"rust-analyzer","type":"text"}],"identifier":"https:\/\/github.com\/rust-analyzer\/rust-analyzer\/","type":"link","title":"rust-analyzer"},"https://github.com/apple/swift/tree/5e2c815edfd758f9b1309ce07bfc01c4bc20ec23/lib/Syntax":{"url":"https:\/\/github.com\/apple\/swift\/tree\/5e2c815edfd758f9b1309ce07bfc01c4bc20ec23\/lib\/Syntax","titleInlineContent":[{"text":"libsyntax","type":"text"}],"identifier":"https:\/\/github.com\/apple\/swift\/tree\/5e2c815edfd758f9b1309ce07bfc01c4bc20ec23\/lib\/Syntax","type":"link","title":"libsyntax"},"doc://Cambium/documentation/Cambium/GettingStarted":{"identifier":"doc:\/\/Cambium\/documentation\/Cambium\/GettingStarted","role":"article","title":"Getting Started","type":"topic","url":"\/documentation\/cambium\/gettingstarted","kind":"article","abstract":[{"text":"Build your first Cambium tree by writing a tiny calculator parser.","type":"text"}]},"https://github.com/rust-analyzer/rowan/":{"url":"https:\/\/github.com\/rust-analyzer\/rowan\/","titleInlineContent":[{"type":"codeVoice","code":"rowan"}],"identifier":"https:\/\/github.com\/rust-analyzer\/rowan\/","type":"link","title":"rowan"}}}