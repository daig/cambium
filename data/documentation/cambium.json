{"topicSections":[{"anchor":"Essentials","identifiers":["doc:\/\/Cambium\/documentation\/Cambium\/GettingStarted"],"title":"Essentials"}],"variants":[{"paths":["\/documentation\/cambium"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","abstract":[{"text":"A Swift-native concrete syntax tree library inspired by Rust’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"reference"},{"text":".","type":"text"}],"metadata":{"modules":[{"name":"Cambium"}],"roleHeading":"Framework","role":"collection","externalID":"Cambium","title":"Cambium","symbolKind":"module"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Cambium is a generic library for creating and working with "},{"type":"strong","inlineContent":[{"text":"concrete","type":"text"},{"text":" ","type":"text"},{"text":"syntax trees","type":"text"}]},{"type":"text","text":" (CSTs)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"“Traditional” abstract syntax trees (ASTs) usually contain different"},{"type":"text","text":" "},{"type":"text","text":"types of nodes which represent different syntactical elements of the"},{"type":"text","text":" "},{"type":"text","text":"source text of a document and reduce its information to the minimal"},{"type":"text","text":" "},{"type":"text","text":"amount necessary to correctly interpret it. In contrast, CSTs are"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"lossless","type":"text"}]},{"type":"text","text":" representations of the entire input where all tree nodes"},{"type":"text","text":" "},{"type":"text","text":"are represented homogeneously (the nodes are "},{"type":"emphasis","inlineContent":[{"text":"untyped","type":"text"}]},{"type":"text","text":") but tagged"},{"type":"text","text":" "},{"type":"text","text":"with a "},{"code":"CambiumCore\/RawSyntaxKind","type":"codeVoice"},{"type":"text","text":" to determine the kind of grammatical element"},{"type":"text","text":" "},{"type":"text","text":"they represent."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"One big advantage of this representation is that it can recreate the"},{"type":"text","text":" "},{"type":"text","text":"original source exactly while also lending itself very well to the"},{"type":"text","text":" "},{"type":"text","text":"representation of "},{"type":"emphasis","inlineContent":[{"text":"incomplete or erroneous","type":"text"}]},{"type":"text","text":" trees and is thus highly"},{"type":"text","text":" "},{"type":"text","text":"suited for usage in contexts such as IDEs or any other application"},{"type":"text","text":" "},{"type":"text","text":"where a user is "},{"type":"emphasis","inlineContent":[{"text":"editing","type":"text"}]},{"type":"text","text":" the source text."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The concept and the data structures for Cambium’s syntax trees are"},{"type":"text","text":" "},{"type":"text","text":"inspired in part by Swift’s"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/apple\/swift\/tree\/5e2c815edfd758f9b1309ce07bfc01c4bc20ec23\/lib\/Syntax","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and by the Rust "},{"type":"reference","identifier":"https:\/\/github.com\/domenicquirl\/cstree","isActive":true},{"type":"text","text":" "},{"type":"text","text":"library, which itself is a fork of"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/rust-analyzer\/rowan\/","isActive":true},{"type":"text","text":" developed by the"},{"type":"text","text":" "},{"type":"text","text":"authors of "},{"type":"reference","identifier":"https:\/\/github.com\/rust-analyzer\/rust-analyzer\/","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Two-layer-storage","level":3,"text":"Two-layer storage","type":"heading"},{"inlineContent":[{"type":"text","text":"Trees consist of two layers:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The inner "},{"inlineContent":[{"type":"text","text":"green tree"}],"type":"strong"},{"type":"text","text":" contains the actual source text as"},{"type":"text","text":" "},{"type":"text","text":"position-independent green nodes. Tokens and nodes that appear"},{"type":"text","text":" "},{"type":"text","text":"identically at multiple places in the source are deduplicated in"},{"type":"text","text":" "},{"type":"text","text":"this representation in order to store the tree efficiently. This"},{"type":"text","text":" "},{"type":"text","text":"means that a green tree may structurally be a DAG rather than a"},{"type":"text","text":" "},{"type":"text","text":"unique object per source position."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"To remedy this, the real syntax tree is constructed on top of the"},{"type":"text","text":" "},{"type":"text","text":"green tree as a secondary tree (called the "},{"inlineContent":[{"type":"text","text":"red tree"}],"type":"strong"},{"type":"text","text":") which"},{"type":"text","text":" "},{"type":"text","text":"models the exact source structure."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"As a possible third layer, a strongly typed AST can be built on top of"},{"type":"text","text":" "},{"type":"text","text":"the red tree (see "},{"type":"reference","identifier":"doc:\/\/Cambium\/documentation\/Cambium\/GettingStarted#AST-Layer","isActive":true},{"type":"text","text":")."}],"type":"paragraph"},{"anchor":"Notable-differences-from-cstree","level":3,"text":"Notable differences from `cstree`","type":"heading"},{"inlineContent":[{"type":"text","text":"Cambium tracks "},{"code":"cstree","type":"codeVoice"},{"type":"text","text":"’s practical guarantees but uses modern Swift"},{"type":"text","text":" "},{"type":"text","text":"language features rather than imitating Rust mechanically:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Borrowed cursors are the primary traversal API."}],"type":"strong"},{"type":"text","text":" Walking a tree"},{"type":"text","text":" "},{"type":"text","text":"uses "},{"code":"~Copyable","type":"codeVoice"},{"type":"text","text":" "},{"code":"CambiumCore\/SyntaxNodeCursor","type":"codeVoice"},{"type":"text","text":"s borrowed inside a closure"},{"type":"text","text":" "},{"type":"text","text":"scope. There are no per-node retains during traversal, no implicit"},{"type":"text","text":" "},{"type":"text","text":"array allocation for child iteration, and no surprise copies of"},{"type":"text","text":" "},{"type":"text","text":"red node references. Copyable "},{"code":"CambiumCore\/SyntaxNodeHandle","type":"codeVoice"},{"type":"text","text":"s exist for"},{"type":"text","text":" "},{"type":"text","text":"long-lived references but are an explicit opt-in."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Move-only builders, caches, and trees."}],"type":"strong"},{"type":"text","text":" "},{"code":"CambiumBuilder\/GreenTreeBuilder","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"CambiumBuilder\/GreenNodeCache","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumBuilder\/GreenBuildResult","type":"codeVoice"},{"type":"text","text":", and "},{"code":"CambiumCore\/SyntaxTree","type":"codeVoice"},{"type":"text","text":" are all"},{"type":"text","text":" "},{"code":"~Copyable","type":"codeVoice"},{"type":"text","text":". Ownership boundaries are visible in the type system;"},{"type":"text","text":" "},{"type":"text","text":"you cannot accidentally clone a builder or duplicate a parse cache."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Synchronous traversal, "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":" snapshots."}],"type":"strong"},{"type":"text","text":" Tree navigation"},{"type":"text","text":" "},{"type":"text","text":"never goes through an actor. Once a tree is built it can be"},{"type":"text","text":" "},{"type":"text","text":"promoted to a "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":" "},{"code":"CambiumCore\/SharedSyntaxTree","type":"codeVoice"},{"type":"text","text":" with"},{"type":"text","text":" "},{"code":"CambiumCore\/SyntaxTree\/intoShared()","type":"codeVoice"},{"type":"text","text":" and freely shared across actors and"},{"type":"text","text":" "},{"type":"text","text":"tasks."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Witness-based change tracking."}],"type":"strong"},{"type":"text","text":" Editing a tree returns a"},{"type":"text","text":" "},{"code":"CambiumCore\/ReplacementWitness","type":"codeVoice"},{"type":"text","text":" describing the structural change; an"},{"type":"text","text":" "},{"type":"text","text":"incremental reparse returns a "},{"code":"CambiumIncremental\/ParseWitness","type":"codeVoice"},{"type":"text","text":" listing the subtrees"},{"type":"text","text":" "},{"type":"text","text":"that were carried over by reference. Cambium does not bake an"},{"type":"text","text":" "},{"type":"text","text":"identity-tracker into the core; consumers translate identities"},{"type":"text","text":" "},{"type":"text","text":"through witness chains."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"No mutation in place."}],"type":"strong"},{"type":"text","text":" Trees are persistent. Editing produces a"},{"type":"text","text":" "},{"type":"text","text":"new tree that shares as much green storage with the old as"},{"type":"text","text":" "},{"type":"text","text":"possible."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Strict serialization."}],"type":"strong"},{"type":"text","text":" Snapshots written by"},{"type":"text","text":" "},{"code":"CambiumCore\/SharedSyntaxTree\/serializeGreenSnapshot()","type":"codeVoice"},{"type":"text","text":" and read by"},{"type":"text","text":" "},{"code":"CambiumSerialization\/GreenSnapshotDecoder","type":"codeVoice"},{"type":"text","text":" are length-, hash-, and kind-validated at"},{"type":"text","text":" "},{"type":"text","text":"every record. Bad snapshots are rejected with named errors."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Modules","level":3,"text":"Modules","type":"heading"},{"inlineContent":[{"type":"text","text":"Cambium is split into several focused modules. Importing the umbrella"},{"type":"text","text":" "},{"code":"Cambium","type":"codeVoice"},{"type":"text","text":" module re-exports the runtime modules; test support and macros"},{"type":"text","text":" "},{"type":"text","text":"are imported explicitly when you need them. You can also pick individual"},{"type":"text","text":" "},{"type":"text","text":"modules directly."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumCore"}],"type":"strong"},{"type":"text","text":" — The foundational layer: "},{"code":"CambiumCore\/RawSyntaxKind","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"CambiumCore\/SyntaxLanguage","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumCore\/TextSize","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumCore\/GreenNode","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumCore\/GreenToken","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"CambiumCore\/SyntaxTree","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumCore\/SyntaxNodeCursor","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumCore\/ReplacementWitness","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumBuilder"}],"type":"strong"},{"type":"text","text":" — "},{"code":"CambiumBuilder\/GreenTreeBuilder","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumBuilder\/GreenNodeCache","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"CambiumBuilder\/LocalTokenInterner","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumBuilder\/SharedTokenInterner","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"SharedSyntaxTree.replacing(_:with:cache:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumIncremental"}],"type":"strong"},{"type":"text","text":" — "},{"code":"CambiumIncremental\/ParseInput","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumIncremental\/IncrementalParseSession","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"CambiumIncremental\/ReuseOracle","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumIncremental\/ParseWitness","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumAnalysis"}],"type":"strong"},{"type":"text","text":" — "},{"code":"CambiumAnalysis\/Diagnostic","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumAnalysis\/SyntaxMetadataStore","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"CambiumAnalysis\/ExternalAnalysisCache","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumASTSupport"}],"type":"strong"},{"type":"text","text":" — "},{"code":"CambiumASTSupport\/TypedSyntaxNode","type":"codeVoice"},{"type":"text","text":", "},{"code":"CambiumASTSupport\/TypedNodeHandle","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumOwnedTraversal"}],"type":"strong"},{"type":"text","text":" — Allocating helpers for handle-based"},{"type":"text","text":" "},{"type":"text","text":"traversal: "},{"code":"SyntaxNodeHandle.childHandles","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"SyntaxNodeHandle.descendantHandlesPreorder","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumSerialization"}],"type":"strong"},{"type":"text","text":" — "},{"code":"CambiumSerialization\/GreenSnapshotDecoder","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"serializeGreenSnapshot()","type":"codeVoice"},{"type":"text","text":" extensions."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumTesting"}],"type":"strong"},{"type":"text","text":" — Test-support helpers: "},{"code":"assertRoundTrip(_:equals:)","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"assertTextLength(_:equals:)","type":"codeVoice"},{"type":"text","text":", "},{"code":"debugTree(_:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"CambiumSyntaxMacros"}],"type":"strong"},{"type":"text","text":" — "},{"code":"@CambiumSyntaxKind","type":"codeVoice"},{"type":"text","text":" and "},{"code":"@StaticText","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"macros for deriving "},{"code":"CambiumCore\/SyntaxKind","type":"codeVoice"},{"type":"text","text":" conformance."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Cambium\/documentation\/Cambium"},"hierarchy":{"paths":[[]]},"references":{"https://github.com/apple/swift/tree/5e2c815edfd758f9b1309ce07bfc01c4bc20ec23/lib/Syntax":{"titleInlineContent":[{"text":"libsyntax","type":"text"}],"type":"link","url":"https:\/\/github.com\/apple\/swift\/tree\/5e2c815edfd758f9b1309ce07bfc01c4bc20ec23\/lib\/Syntax","identifier":"https:\/\/github.com\/apple\/swift\/tree\/5e2c815edfd758f9b1309ce07bfc01c4bc20ec23\/lib\/Syntax","title":"libsyntax"},"doc://Cambium/documentation/Cambium/GettingStarted":{"title":"Getting Started","role":"article","type":"topic","kind":"article","abstract":[{"text":"Build your first Cambium tree by writing a tiny calculator parser.","type":"text"}],"url":"\/documentation\/cambium\/gettingstarted","identifier":"doc:\/\/Cambium\/documentation\/Cambium\/GettingStarted"},"doc://Cambium/documentation/Cambium/GettingStarted#AST-Layer":{"type":"topic","url":"\/documentation\/cambium\/gettingstarted#AST-Layer","abstract":[],"identifier":"doc:\/\/Cambium\/documentation\/Cambium\/GettingStarted#AST-Layer","kind":"section","title":"AST Layer"},"doc://Cambium/documentation/Cambium":{"title":"Cambium","role":"collection","type":"topic","kind":"symbol","abstract":[{"text":"A Swift-native concrete syntax tree library inspired by Rust’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/domenicquirl\/cstree","type":"reference"},{"text":".","type":"text"}],"url":"\/documentation\/cambium","identifier":"doc:\/\/Cambium\/documentation\/Cambium"},"https://github.com/domenicquirl/cstree":{"titleInlineContent":[{"code":"cstree","type":"codeVoice"}],"type":"link","url":"https:\/\/github.com\/domenicquirl\/cstree","identifier":"https:\/\/github.com\/domenicquirl\/cstree","title":"cstree"},"https://github.com/rust-analyzer/rowan/":{"titleInlineContent":[{"code":"rowan","type":"codeVoice"}],"type":"link","url":"https:\/\/github.com\/rust-analyzer\/rowan\/","identifier":"https:\/\/github.com\/rust-analyzer\/rowan\/","title":"rowan"},"https://github.com/rust-analyzer/rust-analyzer/":{"titleInlineContent":[{"text":"rust-analyzer","type":"text"}],"type":"link","url":"https:\/\/github.com\/rust-analyzer\/rust-analyzer\/","identifier":"https:\/\/github.com\/rust-analyzer\/rust-analyzer\/","title":"rust-analyzer"}}}