{"abstract":[{"type":"text","text":"A path from a green tree’s root to a descendant node, expressed as the"},{"type":"text","text":" "},{"type":"text","text":"sequence of green child-slot indices (one index per descent step)."}],"metadata":{"symbolKind":"typealias","externalID":"s:11CambiumCore14SyntaxNodePatha","roleHeading":"Type Alias","title":"SyntaxNodePath","navigatorTitle":[{"kind":"identifier","text":"SyntaxNodePath"}],"role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"SyntaxNodePath"}],"modules":[{"name":"CambiumSyntaxMacros"}]},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"SyntaxNodePath"},{"kind":"text","text":" = ["},{"preciseIdentifier":"s:s6UInt32V","kind":"typeIdentifier","text":"UInt32"},{"kind":"text","text":"]"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each index is a position in the parent’s full child list (counting both"},{"type":"text","text":" "},{"type":"text","text":"nodes and tokens), not the node-only count exposed by"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/SyntaxNodeCursor\/childCount"},{"type":"text","text":". This matches the indexing used by"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/SyntaxNodeCursor\/childIndexPath()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/SyntaxNodeCursor\/withDescendant(atPath:_:)"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is intent-only documentation: the compiler treats it as"},{"type":"text","text":" "},{"type":"codeVoice","code":"[UInt32]"},{"type":"text","text":", so it does not enforce path-vs-array distinctions. It"},{"type":"text","text":" "},{"type":"text","text":"exists to make API signatures readable and to leave room for a wrapper"},{"type":"text","text":" "},{"type":"text","text":"type later."}]}]}],"identifier":{"url":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/SyntaxNodePath","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambiumsyntaxmacros\/syntaxnodepath"]}],"references":{"doc://org.cambium.Cambium/documentation/CambiumSyntaxMacros":{"url":"\/documentation\/cambiumsyntaxmacros","kind":"symbol","role":"collection","type":"topic","title":"CambiumSyntaxMacros","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros","abstract":[]},"doc://org.cambium.Cambium/documentation/CambiumSyntaxMacros/SyntaxNodePath":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SyntaxNodePath"}],"title":"SyntaxNodePath","url":"\/documentation\/cambiumsyntaxmacros\/syntaxnodepath","type":"topic","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"SyntaxNodePath"}],"abstract":[{"text":"A path from a green tree’s root to a descendant node, expressed as the","type":"text"},{"text":" ","type":"text"},{"text":"sequence of green child-slot indices (one index per descent step).","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/SyntaxNodePath"}}}