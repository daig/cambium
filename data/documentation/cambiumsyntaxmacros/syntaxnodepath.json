{"sections":[],"abstract":[{"type":"text","text":"A path from a green tree’s root to a descendant node, expressed as the"},{"type":"text","text":" "},{"type":"text","text":"sequence of green child-slot indices (one index per descent step)."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"SyntaxNodePath"},{"kind":"text","text":" = ["},{"kind":"typeIdentifier","text":"UInt32","preciseIdentifier":"s:s6UInt32V"},{"kind":"text","text":"]"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each index is a position in the parent’s full child list (counting both"},{"type":"text","text":" "},{"type":"text","text":"nodes and tokens), not the node-only count exposed by"},{"type":"text","text":" "},{"code":"CambiumCore\/SyntaxNodeCursor\/childCount","type":"codeVoice"},{"type":"text","text":". This matches the indexing used by"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/SyntaxNodeCursor\/childIndexPath()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/SyntaxNodeCursor\/withDescendant(atPath:_:)"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is intent-only documentation: the compiler treats it as"},{"type":"text","text":" "},{"type":"codeVoice","code":"[UInt32]"},{"type":"text","text":", so it does not enforce path-vs-array distinctions. It"},{"type":"text","text":" "},{"type":"text","text":"exists to make API signatures readable and to leave room for a wrapper"},{"type":"text","text":" "},{"type":"text","text":"type later."}]}]}],"kind":"symbol","metadata":{"role":"symbol","roleHeading":"Type Alias","modules":[{"name":"Cambium"}],"title":"SyntaxNodePath","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"SyntaxNodePath"}],"symbolKind":"typealias","navigatorTitle":[{"kind":"identifier","text":"SyntaxNodePath"}],"externalID":"s:11CambiumCore14SyntaxNodePatha"},"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros"]]},"identifier":{"url":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/SyntaxNodePath","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cambiumsyntaxmacros\/syntaxnodepath"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://org.cambium.Cambium/documentation/CambiumSyntaxMacros":{"kind":"symbol","abstract":[],"url":"\/documentation\/cambiumsyntaxmacros","role":"collection","type":"topic","title":"CambiumSyntaxMacros","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros"},"doc://org.cambium.Cambium/documentation/CambiumSyntaxMacros/SyntaxNodePath":{"title":"SyntaxNodePath","abstract":[{"type":"text","text":"A path from a green tree’s root to a descendant node, expressed as the"},{"type":"text","text":" "},{"type":"text","text":"sequence of green child-slot indices (one index per descent step)."}],"navigatorTitle":[{"kind":"identifier","text":"SyntaxNodePath"}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/SyntaxNodePath","type":"topic","kind":"symbol","url":"\/documentation\/cambiumsyntaxmacros\/syntaxnodepath","role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"SyntaxNodePath"}]}}}