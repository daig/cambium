externalParam","text":"with"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ResolvedGreenNode","preciseIdentifier":"s:11CambiumCore17ResolvedGreenNodeV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Lang"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"GreenNodeCache","preciseIdentifier":"s:14CambiumBuilder14GreenNodeCacheV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Lang"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"ReplacementResult","preciseIdentifier":"s:11CambiumCore17ReplacementResultV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Lang"},{"kind":"text","text":">"}],"extendedModule":"CambiumCore","modules":[{"relatedModules":["CambiumCore"],"name":"Cambium"}],"roleHeading":"Instance Method","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"replacing"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"handle"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/SyntaxNodeHandle","preciseIdentifier":"s:11CambiumCore16SyntaxNodeHandleV","text":"SyntaxNodeHandle"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Lang"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"with"},{"kind":"text","text":" "},{"kind":"internalParam","text":"replacement"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/ResolvedGreenNode","preciseIdentifier":"s:11CambiumCore17ResolvedGreenNodeV","text":"ResolvedGreenNode"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Lang"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/GreenNodeCache","preciseIdentifier":"s:14CambiumBuilder14GreenNodeCacheV","text":"GreenNodeCache"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Lang"},{"kind":"text","text":">) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/ReplacementResult","preciseIdentifier":"s:11CambiumCore17ReplacementResultV","text":"ReplacementResult"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Lang"},{"kind":"text","text":">"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"code":"handle","type":"codeVoice"},{"text":" must be from this tree; passing a handle from a different","type":"text"},{"text":" ","type":"text"},{"text":"tree traps. (Cross-tree replacement is not a meaningful operation —","type":"text"},{"text":" ","type":"text"},{"text":"translate the handle through your own tracker first.)","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For full correctness when sharing a cache across builders or when","type":"text"},{"text":" ","type":"text"},{"text":"the replacement was built independently of this tree, pass a ","type":"text"},{"code":"cache","type":"codeVoice"},{"text":" ","type":"text"},{"text":"whose interner is the one used to build this tree (typically","type":"text"},{"text":" ","type":"text"},{"text":"obtained via ","type":"text"},{"code":"result.intoCache()","type":"codeVoice"},{"text":"). When the cache shares this","type":"text"},{"text":" ","type":"text"},{"text":"tree’s namespace, the result tree’s resolver is a fresh snapshot of","type":"text"},{"text":" ","type":"text"},{"text":"the cache covering every key referenced by the new tree.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In the rare case where the replacement is in the same namespace as","type":"text"},{"text":" ","type":"text"},{"text":"this tree but the cache passed in is in a different namespace, this","type":"text"},{"text":" ","type":"text"},{"text":"tree’s resolver is reused as-is. If the replacement was taken from","type":"text"},{"text":" ","type":"text"},{"text":"a fresher snapshot of the same shared interner, rendering may","type":"text"},{"text":" ","type":"text"},{"text":"precondition-fail on keys that postdate this tree’s snapshot. Pass","type":"text"},{"text":" ","type":"text"},{"text":"a namespace-matching cache to avoid this.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If neither the replacement nor the cache shares this tree’s namespace,"},{"type":"text","text":" "},{"type":"text","text":"replacement falls back to an overlay resolver. That fallback preserves"},{"type":"text","text":" "},{"type":"text","text":"structural sharing and correctness, but intentionally exposes no"},{"type":"text","text":" "},{"type":"codeVoice","code":"tokenKeyNamespace"},{"type":"text","text":"; future "},{"type":"codeVoice","code":"reuseSubtree"},{"type":"text","text":" calls with a cache must"},{"type":"text","text":" "},{"type":"text","text":"remap dynamic token keys instead of direct-reusing the overlay-backed"},{"type":"text","text":" "},{"type":"text","text":"green storage. Revisit this with the broader cache-lineage redesign."}],"type":"paragraph"}]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/SharedSyntaxTree\/replacing(_:with:cache:)-686n2"},"references":{"doc://org.cambium.Cambium/documentation/CambiumSyntaxMac