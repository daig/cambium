":"unorderedList"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Namespace identity.","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumCore\/TokenResolver\/tokenKeyNamespace"},{"type":"text","text":" exposes the runtime"},{"type":"text","text":" "},{"type":"text","text":"identity that builders use to decide whether two trees can share token"},{"type":"text","text":" "},{"type":"text","text":"keys. Resolvers that compose multiple namespaces (overlay resolvers"},{"type":"text","text":" "},{"type":"text","text":"produced by "},{"type":"codeVoice","code":"replacing(_:with:cache:)"},{"type":"text","text":" for incompatible cache lineages)"},{"type":"text","text":" "},{"type":"text","text":"return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" so the builder fall-back path remaps keys conservatively."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros"]]},"metadata":{"symbolKind":"protocol","title":"TokenResolver","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TokenResolver"}],"modules":[{"name":"Cambium"}],"role":"symbol","navigatorTitle":[{"text":"TokenResolver","kind":"identifier"}],"externalID":"s:11CambiumCore13TokenResolverP","roleHeading":"Protocol"},"references":{"doc://org.cambium.Cambium/documentation/CambiumSyntaxMacros/TokenResolver/resolve(_:)":{"kind":"symbol","required":true,"abstract":[{"type":"text","text":"Return the text bound to "},{"type":"codeVoice","code":"key"},{"type":"text","text":". Traps when "},{"type":"codeVoice","code":"key"},{"type":"text","text":" is not present in"},{"type":"text","text":" "},{"type":"text","text":"this resolver’s table."}],"url":"\/documentation\/cambiumsyntaxmacros\/tokenresolver\/resolve(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"resolve","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Toke