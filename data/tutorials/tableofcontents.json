{"kind":"overview","sections":[{"title":"Build a Calculator with Cambium","action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"overridingTitle":"Get started","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage","isActive":true,"type":"reference"},"content":[{"inlineContent":[{"text":"Cambium is a Swift-native concrete syntax tree library. This","type":"text"},{"text":" ","type":"text"},{"text":"tutorial series walks you through building a small but","type":"text"},{"type":"text","text":" "},{"type":"text","text":"production-shaped calculator language end-to-end: a"},{"type":"text","text":" "},{"type":"text","text":"recursive-descent parser that produces a lossless tree, a typed AST overlay,"},{"type":"text","text":" "},{"type":"text","text":"an evaluator with memoized analysis, persistent edits with"},{"type":"text","text":" "},{"text":"identity-preserving witnesses, an incremental reparse loop,","type":"text"},{"text":" ","type":"text"},{"text":"fork-join evaluation across structured-concurrent tasks, parallel","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsing with externalized interning, and on-disk serialization."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Each chapter culminates in REPL commands you can try in the"},{"type":"text","text":" "},{"type":"text","text":"companion sample at "},{"type":"codeVoice","code":"Examples\/Calculator"},{"type":"text","text":". By the end you will"},{"type":"text","text":" "},{"text":"have built the same library that backs the ","type":"text"},{"type":"codeVoice","code":"calc-repl"},{"type":"text","text":" "},{"type":"text","text":"executable, one Cambium subsystem at a time."}],"type":"paragraph"}],"kind":"hero"},{"name":null,"content":[],"kind":"volume","image":null,"chapters":[{"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/02-DriveBuilder","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/03-PrecedenceAndRecovery"],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cambium represents a parsed document as a homogeneous green tree"},{"type":"text","text":" "},{"type":"text","text":"whose nodes are tagged with a kind. In this chapter you define the"},{"type":"text","text":" "},{"type":"text","text":"calculator’s grammar, drive a builder from a recursive-descent"},{"type":"text","text":" "},{"type":"text","text":"parser, and add Pratt-style precedence and parser-level error"},{"type":"text","text":" "},{"type":"text","text":"recovery so the resulting tree round-trips even malformed input."}]}],"image":"chapter-banner.png","name":"Build a Lossless CST"},{"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/04-ReadingTree","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/05-TypedAST","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/06-Evaluator"],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once a tree exists, consumers need to walk it, query it by byte"},{"type":"text","text":" "},{"type":"text","text":"position, and project a typed view for kind-specific work. This"},{"type":"text","text":" "},{"type":"text","text":"chapter introduces borrowed cursors, owned handles, byte-streaming"},{"type":"text","text":" "},{"type":"text","text":"text reads, and a typed AST overlay generated from the"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumSyntaxMacros\/CambiumSyntaxNode(_:for:)"},{"type":"text","text":" macro, then uses"},{"type":"text","text":" "},{"type":"text","text":"them to build a recursive evaluator."}]}],"image":"chapter-banner.png","name":"Read and Model the Tree"},{"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/07-ReplacementWitnesses","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/08-IncrementalReparse","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/09-AnalysisTranslation"],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cambium’s trees are persistent: editing produces a new tree"},{"type":"text","text":" "},{"type":"text","text":"sharing as much green storage as possible, with a witness"},{"type":"text","text":" "},{"type":"text","text":"describing the structural change. This chapter wires up constant"},{"type":"text","text":" "},{"type":"text","text":"folding via subtree replacement, an incremental reparse loop with"},{"type":"text","text":" "},{"type":"text","text":"a reuse oracle, and memoized analysis caches whose entries"},{"type":"text","text":" "},{"type":"text","text":"survive edits by translating through the witnesses."}]}],"image":"chapter-banner.png","name":"Edit, Reparse, and Memoize"},{"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/10-ForkJoinEval","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/11-ParallelParse","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/12-Serialization"],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cambium’s trees promote into "},{"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SharedSyntaxTree","isActive":true},{"type":"text","text":" "},{"type":"text","text":"snapshots that are "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":" and safe to share across tasks. In"},{"type":"text","text":" "},{"type":"text","text":"this chapter you write a structured-concurrent fork-join"},{"type":"text","text":" "},{"type":"text","text":"evaluator, parse a workload of expressions in parallel through a"},{"type":"text","text":" "},{"type":"text","text":"shared token interner, and serialize a tree to disk for"},{"type":"text","text":" "},{"type":"text","text":"editor-style warm restarts."}]}],"image":"chapter-banner.png","name":"Concurrency and Persistence"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reference material that complements the hands-on tutorials."}]}],"kind":"resources","tiles":[{"identifier":"documentation","action":{"type":"link","title":"View more","destination":"https:\/\/xn--wxa.dog\/cambium\/documentation\/cambium\/"},"title":"Documentation","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Articles in the Cambium documentation that complement the"},{"type":"text","text":" "},{"type":"text","text":"hands-on path:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"“Getting Started” — narrative skim of the API."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"“Calculator” — sample-code overview."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"“Externalized Interning” — deep dive on "},{"type":"codeVoice","code":"TokenInterner"},{"type":"text","text":"."}],"type":"paragraph"}]}]}]},{"identifier":"sampleCode","action":{"type":"link","title":"View more","destination":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator"},"title":"Sample Code","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The calculator example is a standalone SwiftPM package at"},{"type":"text","text":" "},{"code":"Examples\/Calculator","type":"codeVoice"},{"type":"text","text":". Each tutorial cites the file in that"},{"type":"text","text":" "},{"type":"text","text":"example whose canonical implementation it builds toward —"},{"type":"text","text":" "},{"type":"text","text":"read them side by side once you have finished the"},{"type":"text","text":" "},{"type":"text","text":"corresponding tutorial."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator","type":"reference","isActive":true},{"type":"text","text":" — the full sample."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md","type":"reference","isActive":true},{"type":"text","text":" — REPL command reference."}],"type":"paragraph"}]}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/tableofcontents"]}],"metadata":{"role":"overview","category":"Cambium","categoryPathComponent":"TableOfContents","estimatedTime":"4hr 50min","title":"Build a Calculator with Cambium"},"hierarchy":{"paths":[],"reference":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents"},"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://org.cambium.Cambium/tutorials/TableOfContents":{"abstract":[{"type":"text","text":"Cambium is a Swift-native concrete syntax tree library. This"},{"type":"text","text":" "},{"type":"text","text":"tutorial series walks you through building a small but"},{"type":"text","text":" "},{"type":"text","text":"production-shaped calculator language end-to-end: a"},{"type":"text","text":" "},{"type":"text","text":"recursive-descent parser that produces a lossless tree, a typed AST overlay,"},{"type":"text","text":" "},{"type":"text","text":"an evaluator with memoized analysis, persistent edits with"},{"type":"text","text":" "},{"type":"text","text":"identity-preserving witnesses, an incremental reparse loop,"},{"text":" ","type":"text"},{"type":"text","text":"fork-join evaluation across structured-concurrent tasks, parallel"},{"text":" ","type":"text"},{"text":"parsing with externalized interning, and on-disk serialization.","type":"text"}],"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents","kind":"overview","title":"Build a Calculator with Cambium","url":"\/tutorials\/tableofcontents","role":"overview","type":"topic"},"doc://org.cambium.Cambium/tutorials/Cambium/04-ReadingTree":{"role":"project","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/04-ReadingTree","estimatedTime":"25min","kind":"project","url":"\/tutorials\/cambium\/04-readingtree","abstract":[{"type":"text","text":"A Cambium tree is meant to be queried frequently — by IDEs on"},{"type":"text","text":" "},{"type":"text","text":"every keystroke, by analyzers walking every node, by formatters"},{"text":" ","type":"text"},{"type":"text","text":"emitting bytes. To stay within reasonable memory and ARC"},{"type":"text","text":" "},{"text":"budgets the primary traversal API is borrowed: walks happen","type":"text"},{"type":"text","text":" "},{"text":"through ","type":"text"},{"type":"codeVoice","code":"~Copyable"},{"text":" cursors handed to a closure, and source","type":"text"},{"type":"text","text":" "},{"text":"text is exposed as a chunk-streaming view rather than a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"materialized "},{"code":"String","type":"codeVoice"},{"type":"text","text":"."}],"title":"Read the Tree Without Allocating"},"doc://org.cambium.Cambium/documentation/CambiumCore/ReplacementWitness":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ReplacementWitness","kind":"identifier"}],"url":"\/documentation\/cambiumcore\/replacementwitness","abstract":[{"type":"text","text":"A pure structural description of a single-subtree replacement applied"},{"type":"text","text":" "},{"type":"text","text":"via "},{"type":"codeVoice","code":"SharedSyntaxTree.replacing(_:with:cache:)"},{"type":"text","text":"."}],"role":"symbol","navigatorTitle":[{"text":"ReplacementWitness","kind":"identifier"}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/ReplacementWitness","kind":"symbol","title":"ReplacementWitness","type":"topic"},"doc://org.cambium.Cambium/tutorials/Cambium/10-ForkJoinEval":{"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/10-ForkJoinEval","title":"Fork-Join Evaluation Across Tasks","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SharedSyntaxTree"},{"type":"text","text":" is "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":". Cambium’s red"},{"type":"text","text":" "},{"type":"text","text":"layer realizes lazily under lock-free atomic slots, so two"},{"type":"text","text":" "},{"type":"text","text":"tasks descending into different siblings of the same parent"},{"type":"text","text":" "},{"type":"text","text":"never observe inconsistent state. The typed AST overlays are"},{"type":"text","text":" "},{"type":"text","text":"also "},{"type":"codeVoice","code":"Sendable, Hashable"},{"type":"text","text":", so passing a sub-expression to a"},{"type":"text","text":" "},{"type":"text","text":"child task is just an argument pass."}],"kind":"project","url":"\/tutorials\/cambium\/10-forkjoineval","role":"project","estimatedTime":"25min","type":"topic"},"doc://org.cambium.Cambium/tutorials/Cambium/01-DefineLanguage":{"abstract":[{"text":"Every Cambium grammar starts with a kind enumeration: one case per","type":"text"},{"text":" ","type":"text"},{"text":"token and one per node the parser can produce. The kind enum","type":"text"},{"text":" ","type":"text"},{"text":"becomes the ","type":"text"},{"code":"Kind","type":"codeVoice"},{"text":" associated type of a ","type":"text"},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SyntaxLanguage","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"conformance, and Cambium specializes its generic types around that","type":"text"},{"type":"text","text":" "},{"text":"language to make tree storage compact and traversal type-safe.","type":"text"}],"type":"topic","estimatedTime":"15min","kind":"project","title":"Define the Calculator Language","url":"\/tutorials\/cambium\/01-definelanguage","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage","role":"project"},"doc://org.cambium.Cambium/documentation/CambiumIncremental":{"url":"\/documentation\/cambiumincremental","title":"CambiumIncremental","kind":"symbol","abstract":[],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental","type":"topic","role":"collection"},"doc://org.cambium.Cambium/documentation/CambiumCore/SyntaxLanguage":{"abstract":[{"text":"The language-level descriptor that gives a Cambium tree its meaning.","type":"text"}],"navigatorTitle":[{"text":"SyntaxLanguage","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SyntaxLanguage","kind":"identifier"}],"type":"topic","url":"\/documentation\/cambiumcore\/syntaxlanguage","role":"symbol","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SyntaxLanguage","title":"SyntaxLanguage","kind":"symbol"},"doc://org.cambium.Cambium/tutorials/Cambium/03-PrecedenceAndRecovery":{"url":"\/tutorials\/cambium\/03-precedenceandrecovery","title":"Add Precedence and Error Recovery","kind":"project","abstract":[{"type":"text","text":"The parser from the previous tutorial handles only “atomic”"},{"type":"text","text":" "},{"type":"text","text":"prefix forms — literals and parenthesized groups. To parse"},{"type":"text","text":" "},{"type":"codeVoice","code":"1 + 2 * 3"},{"type":"text","text":" correctly the parser needs operator precedence; to"},{"type":"text","text":" "},{"type":"text","text":"survive "},{"type":"codeVoice","code":"1 +"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"(2"},{"type":"text","text":" it needs error recovery."}],"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/03-PrecedenceAndRecovery","type":"topic","role":"project","estimatedTime":"30min"},"doc://org.cambium.Cambium/documentation/CambiumCore/SharedSyntaxTree":{"title":"SharedSyntaxTree","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SharedSyntaxTree","role":"symbol","abstract":[{"text":"A copyable, ","type":"text"},{"type":"codeVoice","code":"Sendable"},{"text":", reference-counted view of a syntax tree.","type":"text"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SharedSyntaxTree","kind":"identifier"}],"url":"\/documentation\/cambiumcore\/sharedsyntaxtree","navigatorTitle":[{"text":"SharedSyntaxTree","kind":"identifier"}],"kind":"symbol"},"https://github.com/daig/cambium/tree/main/Examples/Calculator":{"type":"link","identifier":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator","titleInlineContent":[{"code":"Examples\/Calculator","type":"codeVoice"}],"url":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator","title":"Examples\/Calculator"},"doc://org.cambium.Cambium/tutorials/Cambium/12-Serialization":{"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/12-Serialization","abstract":[{"type":"text","text":"Cambium can serialize a tree to a compact byte stream and"},{"type":"text","text":" "},{"type":"text","text":"decode it back. The format is length-, hash-, and"},{"type":"text","text":" "},{"type":"text","text":"kind-validated at every record, so flipped bytes produce"},{"type":"text","text":" "},{"type":"text","text":"named errors at decode time rather than silently malformed"},{"type":"text","text":" "},{"type":"text","text":"trees."}],"title":"Save and Load Trees","type":"topic","estimatedTime":"15min","role":"project","kind":"project","url":"\/tutorials\/cambium\/12-serialization"},"doc://org.cambium.Cambium/tutorials/Cambium/07-ReplacementWitnesses":{"abstract":[{"text":"Cambium trees are persistent: there is no in-place mutation.","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"SharedSyntaxTree.replacing(_:with:context:)"},{"type":"text","text":" produces a "},{"type":"emphasis","inlineContent":[{"text":"new","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"tree that shares as much green storage with"},{"type":"text","text":" "},{"type":"text","text":"the old as possible, and returns a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/ReplacementWitness","isActive":true},{"type":"text","text":" describing the structural"},{"type":"text","text":" "},{"type":"text","text":"change."}],"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/07-ReplacementWitnesses","kind":"project","title":"Replace Subtrees with Witnesses","url":"\/tutorials\/cambium\/07-replacementwitnesses","role":"project","estimatedTime":"25min","type":"topic"},"doc://org.cambium.Cambium/tutorials/Cambium/09-AnalysisTranslation":{"url":"\/tutorials\/cambium\/09-analysistranslation","title":"Translate Analysis Across Edits","kind":"project","abstract":[{"text":"The witnesses you built in Tutorial 7 (replacement) and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Tutorial 8 (reparse) exist to make analysis caches "},{"type":"emphasis","inlineContent":[{"type":"text","text":"survive"},{"text":" ","type":"text"},{"type":"text","text":"edits"}]},{"type":"text","text":". Without translation every keystroke would invalidate"},{"type":"text","text":" "},{"type":"text","text":"every memoized value — defeating the whole point of an"},{"type":"text","text":" "},{"type":"text","text":"incremental tool."}],"type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/09-AnalysisTranslation","role":"project","estimatedTime":"30min"},"doc://org.cambium.Cambium/tutorials/Cambium/08-IncrementalReparse":{"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/08-IncrementalReparse","url":"\/tutorials\/cambium\/08-incrementalreparse","kind":"project","estimatedTime":"30min","type":"topic","title":"Incrementally Reparse","abstract":[{"type":"text","text":"An IDE re-runs the parser on every keystroke. Reparsing the"},{"type":"text","text":" "},{"type":"text","text":"whole document each time is wasteful when most subtrees did"},{"type":"text","text":" "},{"type":"text","text":"not change. "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental","isActive":true,"type":"reference"},{"type":"text","text":" exposes the four pieces"},{"type":"text","text":" "},{"type":"text","text":"you wire together for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"subtree-level"}]},{"type":"text","text":" reuse:"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumIncremental\/IncrementalParseSession"},{"text":" (long-lived","type":"text"},{"text":" ","type":"text"},{"text":"bookkeeping), ","type":"text"},{"type":"codeVoice","code":"CambiumIncremental\/ReuseOracle"},{"text":" (the","type":"text"},{"text":" ","type":"text"},{"text":"parser-facing query API), ","type":"text"},{"type":"codeVoice","code":"CambiumIncremental\/TextEdit"},{"type":"text","text":" "},{"type":"text","text":"(the change description), and"},{"type":"text","text":" "},{"type":"codeVoice","code":"CambiumIncremental\/ParseWitness"},{"type":"text","text":" (the post-parse summary"},{"type":"text","text":" "},{"type":"text","text":"of what was reused)."}],"role":"project"},"doc://org.cambium.Cambium/tutorials/Cambium/06-Evaluator":{"url":"\/tutorials\/cambium\/06-evaluator","kind":"project","title":"Evaluate the Typed AST","abstract":[{"type":"text","text":"With the typed AST in place from Tutorial 5, an evaluator"},{"type":"text","text":" "},{"type":"text","text":"becomes a recursive function that pattern-matches on"},{"type":"text","text":" "},{"type":"codeVoice","code":"ExprSyntax"},{"text":". Each kind has a closed structure — its operands","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and operator are addressable through the typed accessors —"},{"type":"text","text":" "},{"type":"text","text":"so the evaluator stays small and total."}],"type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/06-Evaluator","role":"project","estimatedTime":"20min"},"chapter-banner.png":{"identifier":"chapter-banner.png","alt":"Chapter banner","type":"image","variants":[{"url":"\/images\/org.cambium.Cambium\/chapter-banner.png","traits":["1x","light"]}]},"https://github.com/daig/cambium/blob/main/Examples/Calculator/README.md":{"identifier":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md","type":"link","title":"README.md","titleInlineContent":[{"code":"README.md","type":"codeVoice"}],"url":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md"},"doc://org.cambium.Cambium/tutorials/Cambium/11-ParallelParse":{"role":"project","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/11-ParallelParse","estimatedTime":"25min","kind":"project","url":"\/tutorials\/cambium\/11-parallelparse","abstract":[{"type":"text","text":"Parallel parsing splits work across worker tasks: each"},{"type":"text","text":" "},{"type":"text","text":"worker parses an independent subtree concurrently, then a"},{"type":"text","text":" "},{"type":"text","text":"master builder splices the worker results into one logical"},{"type":"text","text":" "},{"type":"text","text":"tree. The correctness-critical question is how the workers"},{"type":"text","text":" "},{"type":"text","text":"share token-text vocabulary and the green-node namespace."}],"title":"Parallel Parsing with Shared Interning"},"doc://org.cambium.Cambium/tutorials/Cambium/02-DriveBuilder":{"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/02-DriveBuilder","url":"\/tutorials\/cambium\/02-drivebuilder","kind":"project","estimatedTime":"25min","type":"topic","title":"Drive a GreenTreeBuilder","abstract":[{"type":"text","text":"With the kind enum in place, you can write a recursive-descent"},{"text":" ","type":"text"},{"type":"text","text":"parser that emits into a "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/GreenTreeBuilder","isActive":true,"type":"reference"},{"type":"text","text":". The"},{"text":" ","type":"text"},{"type":"text","text":"builder accepts a stream of "},{"type":"codeVoice","code":"startNode"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"token"},{"type":"text","text":" \/ "},{"code":"staticToken","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"\/ "},{"code":"finishNode","type":"codeVoice"},{"type":"text","text":" calls and produces a green tree whose structure"},{"type":"text","text":" "},{"text":"mirrors the calls one-for-one.","type":"text"}],"role":"project"},"doc://org.cambium.Cambium/documentation/CambiumBuilder/GreenTreeBuilder":{"url":"\/documentation\/cambiumbuilder\/greentreebuilder","title":"GreenTreeBuilder","kind":"symbol","abstract":[{"text":"The event-style builder used by parsers to construct a green tree.","type":"text"}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumBuilder\/GreenTreeBuilder","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GreenTreeBuilder","kind":"identifier"}],"navigatorTitle":[{"text":"GreenTreeBuilder","kind":"identifier"}]},"doc://org.cambium.Cambium/tutorials/Cambium/05-TypedAST":{"abstract":[{"type":"text","text":"Cambium’s CST stores everything as homogeneous nodes tagged"},{"type":"text","text":" "},{"type":"text","text":"with a kind. That uniformity is what makes editing and reuse"},{"type":"text","text":" "},{"type":"text","text":"cheap, but it leaves consumers to write "},{"code":"switch node.kind { ... }","type":"codeVoice"},{"type":"text","text":" everywhere they want kind-specific behavior."}],"type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/05-TypedAST","title":"Project a Typed AST Overlay","url":"\/tutorials\/cambium\/05-typedast","role":"project","estimatedTime":"25min","kind":"project"}}}