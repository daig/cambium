{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"Build a Calculator with Cambium","category":"Cambium","categoryPathComponent":"TableOfContents","role":"overview","estimatedTime":"4hr 50min"},"identifier":{"url":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents","interfaceLanguage":"swift"},"kind":"overview","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/tableofcontents"]}],"hierarchy":{"reference":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents","paths":[]},"sections":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cambium is a Swift-native concrete syntax tree library. This"},{"type":"text","text":" "},{"type":"text","text":"tutorial series walks you through building a small but"},{"type":"text","text":" "},{"type":"text","text":"production-shaped calculator language end-to-end: a"},{"type":"text","text":" "},{"type":"text","text":"recursive-descent parser that produces a lossless tree, a typed AST overlay,"},{"type":"text","text":" "},{"type":"text","text":"an evaluator with memoized analysis, persistent edits with"},{"type":"text","text":" "},{"type":"text","text":"identity-preserving witnesses, an incremental reparse loop,"},{"type":"text","text":" "},{"type":"text","text":"fork-join evaluation across structured-concurrent tasks, parallel"},{"type":"text","text":" "},{"type":"text","text":"parsing with externalized interning, and on-disk serialization."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each chapter culminates in REPL commands you can try in the"},{"type":"text","text":" "},{"type":"text","text":"companion sample at "},{"type":"codeVoice","code":"Examples\/Calculator"},{"type":"text","text":". By the end you will"},{"type":"text","text":" "},{"type":"text","text":"have built the same library that backs the "},{"type":"codeVoice","code":"calc-repl"},{"type":"text","text":" "},{"type":"text","text":"executable, one Cambium subsystem at a time."}]}],"title":"Build a Calculator with Cambium","kind":"hero","action":{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"overridingTitle":"Get started"}},{"kind":"volume","content":[],"chapters":[{"name":"Build a Lossless CST","content":[{"inlineContent":[{"text":"Cambium represents a parsed document as a homogeneous green tree","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whose nodes are tagged with a kind. In this chapter you define the"},{"type":"text","text":" "},{"type":"text","text":"calculator’s grammar, drive a builder from a recursive-descent"},{"type":"text","text":" "},{"text":"parser, and add Pratt-style precedence and parser-level error","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recovery so the resulting tree round-trips even malformed input."}],"type":"paragraph"}],"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/02-DriveBuilder","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/03-PrecedenceAndRecovery"],"image":"chapter-banner.png"},{"name":"Read and Model the Tree","content":[{"type":"paragraph","inlineContent":[{"text":"Once a tree exists, consumers need to walk it, query it by byte","type":"text"},{"text":" ","type":"text"},{"text":"position, and project a typed view for kind-specific work. This","type":"text"},{"text":" ","type":"text"},{"text":"chapter introduces borrowed cursors, owned handles, byte-streaming","type":"text"},{"text":" ","type":"text"},{"text":"text reads, and a typed AST overlay generated from the","type":"text"},{"text":" ","type":"text"},{"code":"CambiumSyntaxMacros\/CambiumSyntaxNode(_:for:)","type":"codeVoice"},{"type":"text","text":" macro, then uses"},{"type":"text","text":" "},{"text":"them to build a recursive evaluator.","type":"text"}]}],"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/04-ReadingTree","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/05-TypedAST","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/06-Evaluator"],"image":"chapter-banner.png"},{"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/07-ReplacementWitnesses","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/08-IncrementalReparse","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/09-AnalysisTranslation"],"name":"Edit, Reparse, and Memoize","image":"chapter-banner.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cambium’s trees are persistent: editing produces a new tree"},{"type":"text","text":" "},{"type":"text","text":"sharing as much green storage as possible, with a witness"},{"type":"text","text":" "},{"text":"describing the structural change. This chapter wires up constant","type":"text"},{"type":"text","text":" "},{"type":"text","text":"folding via subtree replacement, an incremental reparse loop with"},{"type":"text","text":" "},{"text":"a reuse oracle, and memoized analysis caches whose entries","type":"text"},{"type":"text","text":" "},{"text":"survive edits by translating through the witnesses.","type":"text"}]}]},{"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/10-ForkJoinEval","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/11-ParallelParse","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/12-Serialization"],"name":"Concurrency and Persistence","image":"chapter-banner.png","content":[{"inlineContent":[{"type":"text","text":"Cambium’s trees promote into "},{"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SharedSyntaxTree","isActive":true},{"type":"text","text":" "},{"type":"text","text":"snapshots that are "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":" and safe to share across tasks. In"},{"type":"text","text":" "},{"type":"text","text":"this chapter you write a structured-concurrent fork-join"},{"type":"text","text":" "},{"type":"text","text":"evaluator, parse a workload of expressions in parallel through a"},{"type":"text","text":" "},{"type":"text","text":"shared token interner, and serialize a tree to disk for"},{"type":"text","text":" "},{"type":"text","text":"editor-style warm restarts."}],"type":"paragraph"}]}],"image":null,"name":null},{"kind":"resources","tiles":[{"title":"Documentation","action":{"title":"View more","type":"link","destination":"https:\/\/xn--wxa.dog\/cambium\/documentation\/cambium\/"},"identifier":"documentation","content":[{"inlineContent":[{"text":"Articles in the Cambium documentation that complement the","type":"text"},{"text":" ","type":"text"},{"text":"hands-on path:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“Getting Started” — narrative skim of the API."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"“Calculator” — sample-code overview."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“Externalized Interning” — deep dive on "},{"code":"TokenInterner","type":"codeVoice"},{"text":".","type":"text"}]}]}]}]},{"title":"Sample Code","action":{"title":"View more","type":"link","destination":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator"},"identifier":"sampleCode","content":[{"inlineContent":[{"type":"text","text":"The calculator example is a standalone SwiftPM package at"},{"type":"text","text":" "},{"type":"codeVoice","code":"Examples\/Calculator"},{"type":"text","text":". Each tutorial cites the file in that"},{"type":"text","text":" "},{"type":"text","text":"example whose canonical implementation it builds toward —"},{"type":"text","text":" "},{"type":"text","text":"read them side by side once you have finished the"},{"type":"text","text":" "},{"type":"text","text":"corresponding tutorial."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator"},{"type":"text","text":" — the full sample."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md"},{"type":"text","text":" — REPL command reference."}],"type":"paragraph"}]}]}]}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reference material that complements the hands-on tutorials."}]}]}],"references":{"https://github.com/daig/cambium/blob/main/Examples/Calculator/README.md":{"identifier":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md","title":"README.md","url":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md","titleInlineContent":[{"code":"README.md","type":"codeVoice"}],"type":"link"},"doc://org.cambium.Cambium/tutorials/Cambium/05-TypedAST":{"url":"\/tutorials\/cambium\/05-typedast","title":"Project a Typed AST Overlay","type":"topic","abstract":[{"type":"text","text":"Cambium’s CST stores everything as homogeneous nodes tagged"},{"type":"text","text":" "},{"type":"text","text":"with a kind. That uniformity is what makes editing and reuse"},{"type":"text","text":" "},{"type":"text","text":"cheap, but it leaves consumers to write "},{"code":"switch node.kind { ... }","type":"codeVoice"},{"type":"text","text":" everywhere they want kind-specific behavior."}],"kind":"project","role":"project","estimatedTime":"25min","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/05-TypedAST"},"doc://org.cambium.Cambium/tutorials/Cambium/01-DefineLanguage":{"url":"\/tutorials\/cambium\/01-definelanguage","title":"Define the Calculator Language","type":"topic","abstract":[{"type":"text","text":"Every Cambium grammar starts with a kind enumeration: one case per"},{"type":"text","text":" "},{"type":"text","text":"token and one per node the parser can produce. The kind enum"},{"type":"text","text":" "},{"type":"text","text":"becomes the "},{"code":"Kind","type":"codeVoice"},{"type":"text","text":" associated type of a "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SyntaxLanguage","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"conformance, and Cambium specializes its generic types around that"},{"type":"text","text":" "},{"type":"text","text":"language to make tree storage compact and traversal type-safe."}],"kind":"project","role":"project","estimatedTime":"15min","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage"},"doc://org.cambium.Cambium/documentation/CambiumIncremental/IncrementalParseSession":{"url":"\/documentation\/cambiumincremental\/incrementalparsesession","title":"IncrementalParseSession","type":"topic","abstract":[{"type":"text","text":"State kept across the lifetime of an incremental parser. Holds"},{"type":"text","text":" "},{"type":"text","text":"offer-side counters (what the "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/ReuseOracle","isActive":true,"type":"reference"},{"type":"text","text":" was asked about) and an"},{"type":"text","text":" "},{"type":"text","text":"accepted-reuse log (what the parser\/builder actually carried over)."}],"kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"IncrementalParseSession"}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/IncrementalParseSession","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"IncrementalParseSession"}]},"doc://org.cambium.Cambium/tutorials/Cambium/09-AnalysisTranslation":{"url":"\/tutorials\/cambium\/09-analysistranslation","title":"Translate Analysis Across Edits","type":"topic","abstract":[{"type":"text","text":"The witnesses you built in Tutorial 7 (replacement) and"},{"type":"text","text":" "},{"type":"text","text":"Tutorial 8 (reparse) exist to make analysis caches "},{"type":"emphasis","inlineContent":[{"text":"survive","type":"text"},{"text":" ","type":"text"},{"text":"edits","type":"text"}]},{"type":"text","text":". Without translation every keystroke would invalidate"},{"type":"text","text":" "},{"type":"text","text":"every memoized value — defeating the whole point of an"},{"text":" ","type":"text"},{"text":"incremental tool.","type":"text"}],"kind":"project","role":"project","estimatedTime":"30min","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/09-AnalysisTranslation"},"doc://org.cambium.Cambium/tutorials/Cambium/11-ParallelParse":{"url":"\/tutorials\/cambium\/11-parallelparse","title":"Parallel Parsing with Shared Interning","type":"topic","abstract":[{"type":"text","text":"Parallel parsing splits work across worker tasks: each"},{"type":"text","text":" "},{"type":"text","text":"worker parses an independent subtree concurrently, then a"},{"type":"text","text":" "},{"type":"text","text":"master builder splices the worker results into one logical"},{"type":"text","text":" "},{"type":"text","text":"tree. The correctness-critical question is how the workers"},{"text":" ","type":"text"},{"text":"share token-text vocabulary and the green-node namespace.","type":"text"}],"kind":"project","role":"project","estimatedTime":"25min","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/11-ParallelParse"},"doc://org.cambium.Cambium/tutorials/Cambium/04-ReadingTree":{"url":"\/tutorials\/cambium\/04-readingtree","abstract":[{"text":"A Cambium tree is meant to be queried frequently — by IDEs on","type":"text"},{"text":" ","type":"text"},{"text":"every keystroke, by analyzers walking every node, by formatters","type":"text"},{"text":" ","type":"text"},{"text":"emitting bytes. To stay within reasonable memory and ARC","type":"text"},{"text":" ","type":"text"},{"text":"budgets the primary traversal API is borrowed: walks happen","type":"text"},{"text":" ","type":"text"},{"text":"through ","type":"text"},{"code":"~Copyable","type":"codeVoice"},{"text":" cursors handed to a closure, and source","type":"text"},{"text":" ","type":"text"},{"text":"text is exposed as a chunk-streaming view rather than a","type":"text"},{"text":" ","type":"text"},{"text":"materialized ","type":"text"},{"code":"String","type":"codeVoice"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/04-ReadingTree","type":"topic","kind":"project","role":"project","title":"Read the Tree Without Allocating","estimatedTime":"25min"},"doc://org.cambium.Cambium/documentation/CambiumIncremental/ParseWitness":{"url":"\/documentation\/cambiumincremental\/parsewitness","abstract":[{"type":"text","text":"A pure structural description of an incremental reparse."}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/ParseWitness","type":"topic","kind":"symbol","role":"symbol","title":"ParseWitness","navigatorTitle":[{"kind":"identifier","text":"ParseWitness"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ParseWitness"}]},"doc://org.cambium.Cambium/documentation/CambiumIncremental/TextEdit":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TextEdit"}],"title":"TextEdit","abstract":[{"type":"text","text":"A single splice on a UTF-8 source document: replace the bytes in"},{"type":"text","text":" "},{"type":"codeVoice","code":"range"},{"type":"text","text":" with "},{"type":"codeVoice","code":"replacementUTF8"},{"type":"text","text":"."}],"url":"\/documentation\/cambiumincremental\/textedit","type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"TextEdit"}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/TextEdit","role":"symbol"},"doc://org.cambium.Cambium/tutorials/Cambium/07-ReplacementWitnesses":{"url":"\/tutorials\/cambium\/07-replacementwitnesses","title":"Replace Subtrees with Witnesses","type":"topic","abstract":[{"text":"Cambium trees are persistent: there is no in-place mutation.","type":"text"},{"text":" ","type":"text"},{"code":"SharedSyntaxTree.replacing(_:with:context:)","type":"codeVoice"},{"text":" produces a ","type":"text"},{"inlineContent":[{"text":"new","type":"text"}],"type":"emphasis"},{"text":" ","type":"text"},{"text":"tree that shares as much green storage with","type":"text"},{"text":" ","type":"text"},{"text":"the old as possible, and returns a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/ReplacementWitness","isActive":true,"type":"reference"},{"text":" describing the structural","type":"text"},{"text":" ","type":"text"},{"text":"change.","type":"text"}],"kind":"project","role":"project","estimatedTime":"25min","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/07-ReplacementWitnesses"},"doc://org.cambium.Cambium/documentation/CambiumIncremental/ReuseOracle":{"url":"\/documentation\/cambiumincremental\/reuseoracle","abstract":[{"text":"A non-copyable, parser-facing oracle that offers candidates from a","type":"text"},{"text":" ","type":"text"},{"text":"previous tree for splicing into a new build.","type":"text"}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/ReuseOracle","type":"topic","kind":"symbol","role":"symbol","title":"ReuseOracle","navigatorTitle":[{"text":"ReuseOracle","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ReuseOracle","kind":"identifier"}]},"chapter-banner.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/org.cambium.Cambium\/chapter-banner.png"}],"identifier":"chapter-banner.png","alt":"Chapter banner","type":"image"},"doc://org.cambium.Cambium/documentation/CambiumCore/SharedSyntaxTree":{"url":"\/documentation\/cambiumcore\/sharedsyntaxtree","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SharedSyntaxTree","kind":"identifier"}],"type":"topic","role":"symbol","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SharedSyntaxTree","navigatorTitle":[{"kind":"identifier","text":"SharedSyntaxTree"}],"title":"SharedSyntaxTree","kind":"symbol","abstract":[{"type":"text","text":"A copyable, "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", reference-counted view of a syntax tree."}]},"doc://org.cambium.Cambium/tutorials/Cambium/08-IncrementalReparse":{"url":"\/tutorials\/cambium\/08-incrementalreparse","abstract":[{"type":"text","text":"An IDE re-runs the parser on every keystroke. Reparsing the"},{"type":"text","text":" "},{"type":"text","text":"whole document each time is wasteful when most subtrees did"},{"type":"text","text":" "},{"type":"text","text":"not change. "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental","isActive":true,"type":"reference"},{"type":"text","text":" exposes the four pieces"},{"type":"text","text":" "},{"type":"text","text":"you wire together for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"subtree-level"}]},{"type":"text","text":" reuse:"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/IncrementalParseSession","isActive":true},{"text":" (long-lived","type":"text"},{"type":"text","text":" "},{"text":"bookkeeping), ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/ReuseOracle"},{"text":" (the","type":"text"},{"text":" ","type":"text"},{"text":"parser-facing query API), ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/TextEdit"},{"text":" ","type":"text"},{"text":"(the change description), and","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental\/ParseWitness","isActive":true,"type":"reference"},{"type":"text","text":" (the post-parse summary"},{"type":"text","text":" "},{"type":"text","text":"of what was reused)."}],"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/08-IncrementalReparse","type":"topic","kind":"project","role":"project","title":"Incrementally Reparse","estimatedTime":"30min"},"doc://org.cambium.Cambium/tutorials/Cambium/03-PrecedenceAndRecovery":{"estimatedTime":"30min","title":"Add Precedence and Error Recovery","abstract":[{"type":"text","text":"The parser from the previous tutorial handles only “atomic”"},{"type":"text","text":" "},{"type":"text","text":"prefix forms — literals and parenthesized groups. To parse"},{"type":"text","text":" "},{"code":"1 + 2 * 3","type":"codeVoice"},{"type":"text","text":" correctly the parser needs operator precedence; to"},{"type":"text","text":" "},{"type":"text","text":"survive "},{"type":"codeVoice","code":"1 +"},{"type":"text","text":" or "},{"type":"codeVoice","code":"(2"},{"type":"text","text":" it needs error recovery."}],"kind":"project","type":"topic","url":"\/tutorials\/cambium\/03-precedenceandrecovery","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/03-PrecedenceAndRecovery","role":"project"},"https://github.com/daig/cambium/tree/main/Examples/Calculator":{"identifier":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator","title":"Examples\/Calculator","url":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator","titleInlineContent":[{"code":"Examples\/Calculator","type":"codeVoice"}],"type":"link"},"doc://org.cambium.Cambium/documentation/CambiumCore/ReplacementWitness":{"url":"\/documentation\/cambiumcore\/replacementwitness","abstract":[{"type":"text","text":"A pure structural description of a single-subtree replacement applied"},{"type":"text","text":" "},{"type":"text","text":"via "},{"type":"codeVoice","code":"SharedSyntaxTree.replacing(_:with:cache:)"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/ReplacementWitness","type":"topic","kind":"symbol","role":"symbol","title":"ReplacementWitness","navigatorTitle":[{"text":"ReplacementWitness","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ReplacementWitness","kind":"identifier"}]},"doc://org.cambium.Cambium/documentation/CambiumCore/SyntaxLanguage":{"title":"SyntaxLanguage","abstract":[{"type":"text","text":"The language-level descriptor that gives a Cambium tree its meaning."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SyntaxLanguage","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SyntaxLanguage","kind":"identifier"}],"type":"topic","role":"symbol","url":"\/documentation\/cambiumcore\/syntaxlanguage","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SyntaxLanguage"},"doc://org.cambium.Cambium/tutorials/Cambium/02-DriveBuilder":{"url":"\/tutorials\/cambium\/02-drivebuilder","title":"Drive a GreenTreeBuilder","type":"topic","abstract":[{"text":"With the kind enum in place, you can write a recursive-descent","type":"text"},{"text":" ","type":"text"},{"text":"parser that emits into a ","type":"text"},{"code":"CambiumBuilder\/GreenTreeBuilder","type":"codeVoice"},{"text":". The","type":"text"},{"text":" ","type":"text"},{"text":"builder accepts a stream of ","type":"text"},{"code":"startNode","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"token","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"staticToken","type":"codeVoice"},{"text":" ","type":"text"},{"text":"\/ ","type":"text"},{"code":"finishNode","type":"codeVoice"},{"text":" calls and produces a green tree whose structure","type":"text"},{"text":" ","type":"text"},{"text":"mirrors the calls one-for-one.","type":"text"}],"kind":"project","role":"project","estimatedTime":"25min","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/02-DriveBuilder"},"doc://org.cambium.Cambium/tutorials/Cambium/06-Evaluator":{"url":"\/tutorials\/cambium\/06-evaluator","abstract":[{"type":"text","text":"With the typed AST in place from Tutorial 5, an evaluator"},{"text":" ","type":"text"},{"text":"becomes a recursive function that pattern-matches on","type":"text"},{"text":" ","type":"text"},{"code":"ExprSyntax","type":"codeVoice"},{"type":"text","text":". Each kind has a closed structure — its operands"},{"text":" ","type":"text"},{"text":"and operator are addressable through the typed accessors —","type":"text"},{"type":"text","text":" "},{"text":"so the evaluator stays small and total.","type":"text"}],"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/06-Evaluator","type":"topic","kind":"project","role":"project","title":"Evaluate the Typed AST","estimatedTime":"20min"},"doc://org.cambium.Cambium/tutorials/Cambium/10-ForkJoinEval":{"url":"\/tutorials\/cambium\/10-forkjoineval","type":"topic","title":"Fork-Join Evaluation Across Tasks","abstract":[{"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumCore\/SharedSyntaxTree","type":"reference","isActive":true},{"text":" is ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":". Cambium’s red","type":"text"},{"text":" ","type":"text"},{"text":"layer realizes lazily under lock-free atomic slots, so two","type":"text"},{"text":" ","type":"text"},{"text":"tasks descending into different siblings of the same parent","type":"text"},{"text":" ","type":"text"},{"text":"never observe inconsistent state. The typed AST overlays are","type":"text"},{"text":" ","type":"text"},{"text":"also ","type":"text"},{"code":"Sendable, Hashable","type":"codeVoice"},{"text":", so passing a sub-expression to a","type":"text"},{"text":" ","type":"text"},{"text":"child task is just an argument pass.","type":"text"}],"kind":"project","role":"project","estimatedTime":"25min","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/10-ForkJoinEval"},"doc://org.cambium.Cambium/tutorials/Cambium/12-Serialization":{"estimatedTime":"15min","title":"Save and Load Trees","abstract":[{"type":"text","text":"Cambium can serialize a tree to a compact byte stream and"},{"type":"text","text":" "},{"type":"text","text":"decode it back. The format is length-, hash-, and"},{"text":" ","type":"text"},{"type":"text","text":"kind-validated at every record, so flipped bytes produce"},{"text":" ","type":"text"},{"text":"named errors at decode time rather than silently malformed","type":"text"},{"type":"text","text":" "},{"text":"trees.","type":"text"}],"url":"\/tutorials\/cambium\/12-serialization","kind":"project","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/12-Serialization","role":"project"},"doc://org.cambium.Cambium/documentation/CambiumIncremental":{"url":"\/documentation\/cambiumincremental","title":"CambiumIncremental","type":"topic","abstract":[],"kind":"symbol","role":"collection","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental"},"doc://org.cambium.Cambium/tutorials/TableOfContents":{"title":"Build a Calculator with Cambium","abstract":[{"text":"Cambium is a Swift-native concrete syntax tree library. This","type":"text"},{"text":" ","type":"text"},{"text":"tutorial series walks you through building a small but","type":"text"},{"text":" ","type":"text"},{"text":"production-shaped calculator language end-to-end: a","type":"text"},{"text":" ","type":"text"},{"text":"recursive-descent parser that produces a lossless tree, a typed AST overlay,","type":"text"},{"text":" ","type":"text"},{"text":"an evaluator with memoized analysis, persistent edits with","type":"text"},{"text":" ","type":"text"},{"text":"identity-preserving witnesses, an incremental reparse loop,","type":"text"},{"text":" ","type":"text"},{"text":"fork-join evaluation across structured-concurrent tasks, parallel","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsing with externalized interning, and on-disk serialization."}],"url":"\/tutorials\/tableofcontents","kind":"overview","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents","role":"overview"}}}