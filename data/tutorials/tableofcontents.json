{"kind":"overview","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"Build a Calculator with Cambium","role":"overview","categoryPathComponent":"TableOfContents","estimatedTime":"4hr 50min","category":"Cambium"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/tableofcontents"]}],"hierarchy":{"reference":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents","paths":[]},"sections":[{"kind":"hero","title":"Build a Calculator with Cambium","action":{"overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage","type":"reference","isActive":true},"content":[{"inlineContent":[{"type":"text","text":"Cambium is a Swift-native concrete syntax tree library. This"},{"type":"text","text":" "},{"type":"text","text":"tutorial series walks you through building a small but"},{"type":"text","text":" "},{"type":"text","text":"production-shaped calculator language end-to-end: a recursive-"},{"type":"text","text":" "},{"type":"text","text":"descent parser that produces a lossless tree, a typed AST overlay,"},{"type":"text","text":" "},{"type":"text","text":"an evaluator with memoized analysis, persistent edits with"},{"type":"text","text":" "},{"type":"text","text":"identity-preserving witnesses, an incremental reparse loop, fork-"},{"type":"text","text":" "},{"type":"text","text":"join evaluation across structured-concurrent tasks, parallel"},{"type":"text","text":" "},{"type":"text","text":"parsing with externalized interning, and on-disk serialization."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Each chapter culminates in REPL commands you can try in the"},{"type":"text","text":" "},{"type":"text","text":"companion sample at "},{"type":"codeVoice","code":"Examples\/Calculator"},{"type":"text","text":". By the end you will"},{"type":"text","text":" "},{"type":"text","text":"have built the same library that backs the "},{"type":"codeVoice","code":"calc-repl"},{"type":"text","text":" "},{"type":"text","text":"executable, one Cambium subsystem at a time."}],"type":"paragraph"}]},{"kind":"volume","chapters":[{"name":"Build a Lossless CST","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cambium represents a parsed document as a homogeneous green tree"},{"type":"text","text":" "},{"type":"text","text":"whose nodes are tagged with a kind. In this chapter you define the"},{"type":"text","text":" "},{"type":"text","text":"calculator’s grammar, drive a builder from a recursive-descent"},{"type":"text","text":" "},{"type":"text","text":"parser, and add Pratt-style precedence and parser-level error"},{"type":"text","text":" "},{"type":"text","text":"recovery so the resulting tree round-trips even malformed input."}]}],"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/02-DriveBuilder","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/03-PrecedenceAndRecovery"],"image":"chapter-banner.png"},{"name":"Read and Model the Tree","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once a tree exists, consumers need to walk it, query it by byte"},{"type":"text","text":" "},{"type":"text","text":"position, and project a typed view for kind-specific work. This"},{"type":"text","text":" "},{"type":"text","text":"chapter introduces borrowed cursors, owned handles, byte-streaming"},{"type":"text","text":" "},{"type":"text","text":"text reads, and a typed AST overlay generated from the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/CambiumSyntaxNode(_:for:)"},{"type":"text","text":" macro, then uses"},{"type":"text","text":" "},{"type":"text","text":"them to build a recursive evaluator."}]}],"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/04-ReadingTree","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/05-TypedAST","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/06-Evaluator"],"image":"chapter-banner.png"},{"name":"Edit, Reparse, and Memoize","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cambium’s trees are persistent: editing produces a new tree"},{"type":"text","text":" "},{"type":"text","text":"sharing as much green storage as possible, with a witness"},{"type":"text","text":" "},{"type":"text","text":"describing the structural change. This chapter wires up constant"},{"type":"text","text":" "},{"type":"text","text":"folding via subtree replacement, an incremental reparse loop with"},{"type":"text","text":" "},{"type":"text","text":"a reuse oracle, and memoized analysis caches whose entries"},{"type":"text","text":" "},{"type":"text","text":"survive edits by translating through the witnesses."}]}],"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/07-ReplacementWitnesses","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/08-IncrementalReparse","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/09-AnalysisTranslation"],"image":"chapter-banner.png"},{"name":"Concurrency and Persistence","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cambium’s trees promote into "},{"type":"codeVoice","code":"CambiumCore\/SharedSyntaxTree"},{"type":"text","text":" "},{"type":"text","text":"snapshots that are "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":" and safe to share across tasks. In"},{"type":"text","text":" "},{"type":"text","text":"this chapter you write a structured-concurrent fork-join"},{"type":"text","text":" "},{"type":"text","text":"evaluator, parse a workload of expressions in parallel through a"},{"type":"text","text":" "},{"type":"text","text":"shared token interner, and serialize a tree to disk for"},{"type":"text","text":" "},{"type":"text","text":"editor-style warm restarts."}]}],"tutorials":["doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/10-ForkJoinEval","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/11-ParallelParse","doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/12-Serialization"],"image":"chapter-banner.png"}],"image":null,"name":null,"content":[]},{"kind":"resources","tiles":[{"title":"Documentation","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Articles in the Cambium documentation that complement the"},{"type":"text","text":" "},{"type":"text","text":"hands-on path:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"“Getting Started” — narrative skim of the API."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"“Calculator” — sample-code overview."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"“Externalized Interning” — deep dive on "},{"type":"codeVoice","code":"TokenInterner"},{"type":"text","text":"."}],"type":"paragraph"}]}]}],"identifier":"documentation","action":{"type":"link","destination":"https:\/\/xn--wxa.dog\/cambium\/documentation\/cambium\/","title":"View more"}},{"title":"Sample Code","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The calculator example is a standalone SwiftPM package at"},{"type":"text","text":" "},{"type":"codeVoice","code":"Examples\/Calculator"},{"type":"text","text":". Each tutorial cites the file in that"},{"type":"text","text":" "},{"type":"text","text":"example whose canonical implementation it builds toward —"},{"type":"text","text":" "},{"type":"text","text":"read them side by side once you have finished the"},{"type":"text","text":" "},{"type":"text","text":"corresponding tutorial."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator"},{"type":"text","text":" — the full sample."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md"},{"type":"text","text":" — REPL command reference."}],"type":"paragraph"}]}]}],"identifier":"sampleCode","action":{"type":"link","destination":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator","title":"View more"}}],"content":[{"inlineContent":[{"type":"text","text":"Reference material that complements the hands-on tutorials."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents","interfaceLanguage":"swift"},"references":{"doc://org.cambium.Cambium/tutorials/Cambium/10-ForkJoinEval":{"estimatedTime":"25min","url":"\/tutorials\/cambium\/10-forkjoineval","abstract":[{"code":"CambiumCore\/SharedSyntaxTree","type":"codeVoice"},{"type":"text","text":" is "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":". Cambium’s red"},{"type":"text","text":" "},{"type":"text","text":"layer realizes lazily under lock-free atomic slots, so two"},{"type":"text","text":" "},{"type":"text","text":"tasks descending into different siblings of the same parent"},{"type":"text","text":" "},{"type":"text","text":"never observe inconsistent state. The typed AST overlays are"},{"type":"text","text":" "},{"type":"text","text":"also "},{"code":"Sendable, Hashable","type":"codeVoice"},{"type":"text","text":", so passing a sub-expression to a"},{"type":"text","text":" "},{"type":"text","text":"child task is just an argument pass."}],"kind":"project","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/10-ForkJoinEval","title":"Fork-Join Evaluation Across Tasks","role":"project"},"doc://org.cambium.Cambium/tutorials/Cambium/08-IncrementalReparse":{"estimatedTime":"30min","kind":"project","abstract":[{"type":"text","text":"An IDE re-runs the parser on every keystroke. Reparsing the"},{"type":"text","text":" "},{"type":"text","text":"whole document each time is wasteful when most subtrees did"},{"type":"text","text":" "},{"type":"text","text":"not change. "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental"},{"type":"text","text":" exposes the four pieces"},{"text":" ","type":"text"},{"text":"you wire together for ","type":"text"},{"inlineContent":[{"type":"text","text":"subtree-level"}],"type":"emphasis"},{"text":" reuse:","type":"text"},{"text":" ","type":"text"},{"code":"CambiumIncremental\/IncrementalParseSession","type":"codeVoice"},{"text":" (long-lived","type":"text"},{"text":" ","type":"text"},{"text":"bookkeeping), ","type":"text"},{"code":"CambiumIncremental\/ReuseOracle","type":"codeVoice"},{"text":" (the","type":"text"},{"text":" ","type":"text"},{"text":"parser-facing query API), ","type":"text"},{"code":"CambiumIncremental\/TextEdit","type":"codeVoice"},{"text":" ","type":"text"},{"text":"(the change description), and","type":"text"},{"text":" ","type":"text"},{"code":"CambiumIncremental\/ParseWitness","type":"codeVoice"},{"text":" (the post-parse summary","type":"text"},{"text":" ","type":"text"},{"text":"of what was reused).","type":"text"}],"url":"\/tutorials\/cambium\/08-incrementalreparse","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/08-IncrementalReparse","type":"topic","title":"Incrementally Reparse","role":"project"},"https://github.com/daig/cambium/blob/main/Examples/Calculator/README.md":{"title":"README.md","url":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md","type":"link","titleInlineContent":[{"type":"codeVoice","code":"README.md"}],"identifier":"https:\/\/github.com\/daig\/cambium\/blob\/main\/Examples\/Calculator\/README.md"},"doc://org.cambium.Cambium/documentation/CambiumIncremental":{"title":"CambiumIncremental","type":"topic","abstract":[],"kind":"symbol","role":"collection","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumIncremental","url":"\/documentation\/cambiumincremental"},"https://github.com/daig/cambium/tree/main/Examples/Calculator":{"title":"Examples\/Calculator","url":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator","type":"link","titleInlineContent":[{"type":"codeVoice","code":"Examples\/Calculator"}],"identifier":"https:\/\/github.com\/daig\/cambium\/tree\/main\/Examples\/Calculator"},"doc://org.cambium.Cambium/tutorials/Cambium/07-ReplacementWitnesses":{"estimatedTime":"25min","url":"\/tutorials\/cambium\/07-replacementwitnesses","abstract":[{"text":"Cambium trees are persistent: there is no in-place mutation.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"SharedSyntaxTree.replacing(_:with:context:)"},{"text":" produces a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"new"}]},{"text":" ","type":"text"},{"text":"tree that shares as much green storage with","type":"text"},{"text":" ","type":"text"},{"text":"the old as possible, and returns a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CambiumCore\/ReplacementWitness"},{"text":" describing the structural","type":"text"},{"text":" ","type":"text"},{"text":"change.","type":"text"}],"kind":"project","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/07-ReplacementWitnesses","title":"Replace Subtrees with Witnesses","role":"project"},"doc://org.cambium.Cambium/documentation/CambiumSyntaxMacros/CambiumSyntaxNode(_:for:)":{"type":"topic","kind":"symbol","url":"\/documentation\/cambiumsyntaxmacros\/cambiumsyntaxnode(_:for:)","abstract":[{"text":"Generate the standard stored syntax handle and unchecked initializer for a","type":"text"},{"text":" ","type":"text"},{"text":"concrete typed syntax-node wrapper.","type":"text"}],"fragments":[{"kind":"keyword","text":"macro"},{"kind":"text","text":" "},{"kind":"identifier","text":"CambiumSyntaxNode"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Kind"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:19CambiumSyntaxMacros4KindL_xmfp","text":"Kind"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"for"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:19CambiumSyntaxMacros4KindL_xmfp","text":"Kind"},{"kind":"text","text":")"}],"role":"symbol","title":"CambiumSyntaxNode(_:for:)","identifier":"doc:\/\/org.cambium.Cambium\/documentation\/CambiumSyntaxMacros\/CambiumSyntaxNode(_:for:)"},"doc://org.cambium.Cambium/tutorials/Cambium/01-DefineLanguage":{"role":"project","abstract":[{"type":"text","text":"Every Cambium grammar starts with a kind enumeration: one case per"},{"type":"text","text":" "},{"type":"text","text":"token and one per node the parser can produce. The kind enum"},{"type":"text","text":" "},{"type":"text","text":"becomes the "},{"type":"codeVoice","code":"Kind"},{"type":"text","text":" associated type of a "},{"type":"codeVoice","code":"CambiumCore\/SyntaxLanguage"},{"type":"text","text":" "},{"type":"text","text":"conformance, and Cambium specializes its generic types around that"},{"type":"text","text":" "},{"type":"text","text":"language to make tree storage compact and traversal type-safe."}],"url":"\/tutorials\/cambium\/01-definelanguage","title":"Define the Calculator Language","type":"topic","estimatedTime":"15min","kind":"project","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/01-DefineLanguage"},"doc://org.cambium.Cambium/tutorials/Cambium/12-Serialization":{"role":"project","abstract":[{"type":"text","text":"Cambium can serialize a tree to a compact byte stream and"},{"type":"text","text":" "},{"type":"text","text":"decode it back. The format is length-, hash-, and"},{"type":"text","text":" "},{"type":"text","text":"kind-validated at every record, so flipped bytes produce"},{"type":"text","text":" "},{"type":"text","text":"named errors at decode time rather than silently malformed"},{"type":"text","text":" "},{"type":"text","text":"trees."}],"url":"\/tutorials\/cambium\/12-serialization","title":"Save and Load Trees","type":"topic","estimatedTime":"15min","kind":"project","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/12-Serialization"},"doc://org.cambium.Cambium/tutorials/TableOfContents":{"url":"\/tutorials\/tableofcontents","abstract":[{"type":"text","text":"Cambium is a Swift-native concrete syntax tree library. This"},{"type":"text","text":" "},{"type":"text","text":"tutorial series walks you through building a small but"},{"type":"text","text":" "},{"type":"text","text":"production-shaped calculator language end-to-end: a recursive-"},{"type":"text","text":" "},{"type":"text","text":"descent parser that produces a lossless tree, a typed AST overlay,"},{"type":"text","text":" "},{"type":"text","text":"an evaluator with memoized analysis, persistent edits with"},{"type":"text","text":" "},{"type":"text","text":"identity-preserving witnesses, an incremental reparse loop, fork-"},{"type":"text","text":" "},{"type":"text","text":"join evaluation across structured-concurrent tasks, parallel"},{"type":"text","text":" "},{"type":"text","text":"parsing with externalized interning, and on-disk serialization."}],"kind":"overview","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/TableOfContents","title":"Build a Calculator with Cambium","role":"overview"},"doc://org.cambium.Cambium/tutorials/Cambium/04-ReadingTree":{"role":"project","abstract":[{"type":"text","text":"A Cambium tree is meant to be queried frequently — by IDEs on"},{"type":"text","text":" "},{"type":"text","text":"every keystroke, by analyzers walking every node, by formatters"},{"type":"text","text":" "},{"type":"text","text":"emitting bytes. To stay within reasonable memory and ARC"},{"type":"text","text":" "},{"type":"text","text":"budgets the primary traversal API is borrowed: walks happen"},{"type":"text","text":" "},{"type":"text","text":"through "},{"type":"codeVoice","code":"~Copyable"},{"type":"text","text":" cursors handed to a closure, and source"},{"type":"text","text":" "},{"type":"text","text":"text is exposed as a chunk-streaming view rather than a"},{"type":"text","text":" "},{"type":"text","text":"materialized "},{"type":"codeVoice","code":"String"},{"type":"text","text":"."}],"url":"\/tutorials\/cambium\/04-readingtree","title":"Read the Tree Without Allocating","type":"topic","estimatedTime":"25min","kind":"project","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/04-ReadingTree"},"doc://org.cambium.Cambium/tutorials/Cambium/03-PrecedenceAndRecovery":{"role":"project","abstract":[{"text":"The parser from the previous tutorial handles only “atomic”","type":"text"},{"type":"text","text":" "},{"text":"prefix forms — literals and parenthesized groups. To parse","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"1 + 2 * 3"},{"type":"text","text":" correctly the parser needs operator precedence; to"},{"text":" ","type":"text"},{"type":"text","text":"survive "},{"type":"codeVoice","code":"1 +"},{"type":"text","text":" or "},{"type":"codeVoice","code":"(2"},{"type":"text","text":" it needs error recovery."}],"url":"\/tutorials\/cambium\/03-precedenceandrecovery","title":"Add Precedence and Error Recovery","type":"topic","estimatedTime":"30min","kind":"project","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/03-PrecedenceAndRecovery"},"doc://org.cambium.Cambium/tutorials/Cambium/05-TypedAST":{"estimatedTime":"25min","kind":"project","url":"\/tutorials\/cambium\/05-typedast","abstract":[{"text":"Cambium’s CST stores everything as homogeneous nodes tagged","type":"text"},{"text":" ","type":"text"},{"text":"with a kind. That uniformity is what makes editing and reuse","type":"text"},{"text":" ","type":"text"},{"text":"cheap, but it leaves consumers to write ","type":"text"},{"code":"switch node.kind { ... }","type":"codeVoice"},{"text":" everywhere they want kind-specific behavior.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/05-TypedAST","title":"Project a Typed AST Overlay","role":"project"},"doc://org.cambium.Cambium/tutorials/Cambium/09-AnalysisTranslation":{"role":"project","abstract":[{"type":"text","text":"The witnesses you built in Tutorial 7 (replacement) and"},{"type":"text","text":" "},{"type":"text","text":"Tutorial 8 (reparse) exist to make analysis caches "},{"inlineContent":[{"type":"text","text":"survive"},{"type":"text","text":" "},{"type":"text","text":"edits"}],"type":"emphasis"},{"type":"text","text":". Without translation every keystroke would invalidate"},{"type":"text","text":" "},{"type":"text","text":"every memoized value — defeating the whole point of an"},{"type":"text","text":" "},{"type":"text","text":"incremental tool."}],"url":"\/tutorials\/cambium\/09-analysistranslation","title":"Translate Analysis Across Edits","type":"topic","estimatedTime":"30min","kind":"project","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/09-AnalysisTranslation"},"doc://org.cambium.Cambium/tutorials/Cambium/02-DriveBuilder":{"estimatedTime":"25min","url":"\/tutorials\/cambium\/02-drivebuilder","abstract":[{"text":"With the kind enum in place, you can write a recursive-descent","type":"text"},{"text":" ","type":"text"},{"text":"parser that emits into a ","type":"text"},{"code":"CambiumBuilder\/GreenTreeBuilder","type":"codeVoice"},{"text":". The","type":"text"},{"text":" ","type":"text"},{"text":"builder accepts a stream of ","type":"text"},{"code":"startNode","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"token","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"staticToken","type":"codeVoice"},{"text":" ","type":"text"},{"text":"\/ ","type":"text"},{"code":"finishNode","type":"codeVoice"},{"text":" calls and produces a green tree whose structure","type":"text"},{"type":"text","text":" "},{"type":"text","text":"mirrors the calls one-for-one."}],"kind":"project","type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/02-DriveBuilder","title":"Drive a GreenTreeBuilder","role":"project"},"doc://org.cambium.Cambium/tutorials/Cambium/06-Evaluator":{"estimatedTime":"20min","kind":"project","url":"\/tutorials\/cambium\/06-evaluator","abstract":[{"text":"With the typed AST in place from Tutorial 5, an evaluator","type":"text"},{"text":" ","type":"text"},{"text":"becomes a recursive function that pattern-matches on","type":"text"},{"text":" ","type":"text"},{"code":"ExprSyntax","type":"codeVoice"},{"text":". Each kind has a closed structure — its operands","type":"text"},{"text":" ","type":"text"},{"text":"and operator are addressable through the typed accessors —","type":"text"},{"text":" ","type":"text"},{"text":"so the evaluator stays small and total.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/06-Evaluator","title":"Evaluate the Typed AST","role":"project"},"chapter-banner.png":{"variants":[{"url":"\/images\/org.cambium.Cambium\/chapter-banner.png","traits":["1x","light"]}],"type":"image","alt":"Chapter banner","identifier":"chapter-banner.png"},"doc://org.cambium.Cambium/tutorials/Cambium/11-ParallelParse":{"role":"project","abstract":[{"type":"text","text":"Parallel parsing splits work across worker tasks: each"},{"type":"text","text":" "},{"type":"text","text":"worker parses an independent subtree concurrently, then a"},{"type":"text","text":" "},{"type":"text","text":"master builder splices the worker results into one logical"},{"type":"text","text":" "},{"type":"text","text":"tree. The correctness-critical question is how the workers"},{"type":"text","text":" "},{"type":"text","text":"share token-text vocabulary and the green-node namespace."}],"url":"\/tutorials\/cambium\/11-parallelparse","title":"Parallel Parsing with Shared Interning","type":"topic","estimatedTime":"25min","kind":"project","identifier":"doc:\/\/org.cambium.Cambium\/tutorials\/Cambium\/11-ParallelParse"}}}